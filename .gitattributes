# Auto detect text files and perform LF normalization
* text=auto

# Linux Docker/WSL: shell scripts must be LF (CRLF breaks shebangs in containers)
tools/MlSpecularTrainer/docker/** text eol=lf
tools/MlSpecularTrainer/run_ml_container.sh text eol=lf
tools/MlSpecularTrainer/training_menu.sh text eol=lf
*.pdb filter=lfs diff=lfs merge=lfs -text
*.dll filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text
