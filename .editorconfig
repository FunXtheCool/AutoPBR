root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
indent_style = space
indent_size = 4

[*.cs]
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true
csharp_new_line_before_open_brace = all
csharp_indent_case_contents = true
csharp_prefer_braces = true:suggestion

# ReSharper: enforce removal of redundant usings and qualifiers
resharper_redundant_using_directive_highlighting = warning
resharper_redundant_qualified_name_highlighting = warning

# ReSharper: prefer async overloads when available (e.g., CancelAsync)
resharper_use_async_overload_highlighting = warning

# ReSharper: prefer explicit nullable-friendly APIs
resharper_null_coalescing_condition_is_always_true_highlighting = suggestion

# ReSharper: keep code style consistent for var usage
resharper_use_var_for_built_in_types = false
resharper_use_var_for_simple_types = false
resharper_use_var_for_anonymous_types = true

