#version 400 core
// Genesis high-end preview tessellation control stage.
// Mirrors Iris shaderpack constraints: triangle patches for geometry-style rendering.

layout(vertices = 3) out;

in vec3 vWorldPos[];
in vec3 vWorldNormal[];
in vec2 vUv[];
in vec4 vWorldTangent[];
in vec4 vLightClip[];
in vec4 vCurrClip[];
in vec4 vPrevClip[];

out vec3 tcWorldPos[];
out vec3 tcWorldNormal[];
out vec2 tcUv[];
out vec4 tcWorldTangent[];
out vec4 tcLightClip[];
out vec4 tcCurrClip[];
out vec4 tcPrevClip[];

uniform int   uEnableTessellationDisplacement;
uniform int   uHasHeight;
uniform float uTessellationLevel;

void main()
{
    tcWorldPos[gl_InvocationID] = vWorldPos[gl_InvocationID];
    tcWorldNormal[gl_InvocationID] = vWorldNormal[gl_InvocationID];
    tcUv[gl_InvocationID] = vUv[gl_InvocationID];
    tcWorldTangent[gl_InvocationID] = vWorldTangent[gl_InvocationID];
    tcLightClip[gl_InvocationID] = vLightClip[gl_InvocationID];
    tcCurrClip[gl_InvocationID] = vCurrClip[gl_InvocationID];
    tcPrevClip[gl_InvocationID] = vPrevClip[gl_InvocationID];
    gl_out[gl_InvocationID].gl_Position = gl_in[gl_InvocationID].gl_Position;

    if (gl_InvocationID == 0)
    {
        float level = (uEnableTessellationDisplacement > 0 && uHasHeight > 0)
            ? clamp(uTessellationLevel, 1.0, 16.0)
            : 1.0;
        gl_TessLevelOuter[0] = level;
        gl_TessLevelOuter[1] = level;
        gl_TessLevelOuter[2] = level;
        gl_TessLevelInner[0] = level;
    }
}
