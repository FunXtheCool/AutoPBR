<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\AutoPBR-logo.ico</ApplicationIcon>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>
  <!-- Generate .ico from PNG for exe/shortcut icon (run when logo.png exists). -->
  <Target Name="GenerateAppIcon" BeforeTargets="BeforeBuild" Condition="Exists('$(ProjectDir)Assets\AutoPBR-logo.png')">
    <Exec Command="dotnet run --project &quot;$(ProjectDir)..\AutoPBR.Tools.GenerateIcon\AutoPBR.Tools.GenerateIcon.csproj&quot; -- &quot;$(ProjectDir)Assets\AutoPBR-logo.png&quot; &quot;$(ProjectDir)Assets\AutoPBR-logo.ico&quot;" IgnoreExitCode="true" />
  </Target>
  <Target Name="GeneratePreviewCloudAssets" BeforeTargets="BeforeBuild" Condition="!Exists('$(ProjectDir)Assets\Preview\cloud_noise_shape_128.bin')">
    <Exec Command="dotnet run --project &quot;$(ProjectDir)..\AutoPBR.Tools.GeneratePreviewCloudAssets\AutoPBR.Tools.GeneratePreviewCloudAssets.csproj&quot; -- &quot;$(ProjectDir)Assets\Preview&quot;" />
  </Target>
  <Target Name="GeneratePreviewGroundAssets" BeforeTargets="BeforeBuild" Condition="!Exists('$(ProjectDir)Assets\Preview\grass_block_top_n.png')">
    <Exec Command="dotnet run --project &quot;$(ProjectDir)..\AutoPBR.Tools.GeneratePreviewGroundAssets\AutoPBR.Tools.GeneratePreviewGroundAssets.csproj&quot; -- &quot;$(ProjectDir)Assets\Preview\grass_block_top.png&quot; &quot;$(ProjectDir)Assets\Preview&quot;" />
  </Target>

  <ItemGroup>
    <Folder Include="Models\" />
    <AvaloniaResource Include="Assets\**" />
    <AvaloniaResource Include="Rendering\Shaders\**" />
    <InternalsVisibleTo Include="AutoPBR.App.Tests" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Update="Lang\Resources.resx">
      <Generator></Generator>
      <LastGenOutput></LastGenOutput>
    </EmbeddedResource>
    <EmbeddedResource Update="Lang\Resources.de.resx">
      <Generator></Generator>
    </EmbeddedResource>
    <EmbeddedResource Update="Lang\Resources.es.resx">
      <Generator></Generator>
    </EmbeddedResource>
    <EmbeddedResource Update="Lang\Resources.fr.resx">
      <Generator></Generator>
    </EmbeddedResource>
    <EmbeddedResource Update="Lang\Resources.pt.resx">
      <Generator></Generator>
    </EmbeddedResource>
    <EmbeddedResource Update="Lang\Resources.ru.resx">
      <Generator></Generator>
    </EmbeddedResource>
    <EmbeddedResource Update="Lang\Resources.ja.resx">
      <Generator></Generator>
    </EmbeddedResource>
    <EmbeddedResource Update="Lang\Resources.zh-Hans.resx">
      <Generator></Generator>
    </EmbeddedResource>
    <EmbeddedResource Update="Lang\Resources.hi.resx">
      <Generator></Generator>
    </EmbeddedResource>
    <EmbeddedResource Update="Lang\Resources.ar.resx">
      <Generator></Generator>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="Avalonia.Fonts.Inter" />
    <!--Condition below is needed to remove Avalonia.Diagnostics package from build output in Release configuration.-->
    <PackageReference Include="Avalonia.Diagnostics">
      <IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
      <PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Silk.NET.OpenGL" />
    <PackageReference Include="SixLabors.ImageSharp" />
    <PackageReference Include="CommunityToolkit.Mvvm" />
    <PackageReference Include="JetBrains.Annotations" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="AutoPBR.Contracts.Ml" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AutoPBR.Contracts\AutoPBR.Contracts.csproj" />
    <ProjectReference Include="..\AutoPBR.Core\AutoPBR.Core.csproj" />
    <ProjectReference Include="..\AutoPBR.Preview\AutoPBR.Preview.csproj" />
    <ProjectReference Include="..\AutoPBR.PreviewGpuAssets\AutoPBR.PreviewGpuAssets.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\AutoPBR.Core\Data\textures_data.json" Link="Data\textures_data.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\AutoPBR.Core\Data\ONNX-AI\DeepBump\*.onnx" Link="Data\ONNX-AI\DeepBump\%(Filename)%(Extension)">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\AutoPBR.Core\Data\ONNX-AI\SpecLab\*.onnx" Link="Data\ONNX-AI\SpecLab\%(Filename)%(Extension)">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\AutoPBR.Core\Data\ONNX-AI\all-MiniLM-L6-v2-onnx\**\*">
      <Link>Data\ONNX-AI\all-MiniLM-L6-v2-onnx\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- CUDA/cuDNN/TensorRT DLLs from Core Data\native; copied to runtimes\win-x64\native for ONNX GPU -->
    <Content Include="..\AutoPBR.Core\Data\native\*.dll" Link="runtimes\win-x64\native\%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- Satellite cultures: must match Lang\Resources.*.resx (excluding default Resources.resx). -->
  <ItemGroup>
    <_SatelliteCulture Include="de;es;fr;pt;ru;ja;zh-Hans;hi;ar" />
  </ItemGroup>

  <!-- Build: copy satellite assemblies to lang\culture\ so app finds them in lang\ and publish can still copy from culture\. -->
  <Target Name="CopySatellitesToLang" AfterTargets="Build">
    <ItemGroup>
      <_SatelliteFiles Include="$(OutputPath)%(_SatelliteCulture.Identity)\*" />
    </ItemGroup>
    <MakeDir Directories="$(OutputPath)lang\%(_SatelliteCulture.Identity)" />
    <Copy SourceFiles="@(_SatelliteFiles)" DestinationFolder="$(OutputPath)lang\%(_SatelliteCulture.Identity)\" SkipUnchangedFiles="true" Condition="Exists('$(OutputPath)%(_SatelliteCulture.Identity)')" />
  </Target>

  <!-- Publish: move satellite assemblies from culture\ to lang\culture\ in publish output (same layout as build). -->
  <Target Name="MoveSatellitesToLangAfterPublish" AfterTargets="Publish" Condition="'$(PublishDir)' != ''">
    <MakeDir Directories="$(PublishDir)lang\%(_SatelliteCulture.Identity)" />
    <RemoveDir Directories="$(PublishDir)lang\%(_SatelliteCulture.Identity)" Condition="Exists('$(PublishDir)lang\%(_SatelliteCulture.Identity)')" />
    <Exec Command="move /Y &quot;$(PublishDir)%(_SatelliteCulture.Identity)&quot; &quot;$(PublishDir)lang\%(_SatelliteCulture.Identity)&quot;" Condition="Exists('$(PublishDir)%(_SatelliteCulture.Identity)') and '$(OS)' == 'Windows_NT'" />
    <Exec Command="mv &quot;$(PublishDir)%(_SatelliteCulture.Identity)&quot; &quot;$(PublishDir)lang/%(_SatelliteCulture.Identity)&quot;" Condition="Exists('$(PublishDir)%(_SatelliteCulture.Identity)') and '$(OS)' != 'Windows_NT'" />
  </Target>
</Project>
