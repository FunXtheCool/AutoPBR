<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AutoPBR.App.ViewModels"
        x:Class="AutoPBR.App.Views.EntityPreviewDebugWindow"
        x:DataType="vm:EntityPreviewDebugWindowViewModel"
        Width="760"
        Height="820"
        MinWidth="560"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="None">
    <Border Background="{Binding WindowBackground}"
            BorderBrush="{Binding CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="1">
        <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0"
                    Height="40"
                    Background="{Binding WindowBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="0,0,0,1"
                    PointerPressed="TitleBarDragRegion_PointerPressed">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding Strings.EntityPreviewDebugTitle}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{Binding ForegroundBrush}" />
                    <Button Grid.Column="1"
                            Width="36"
                            Height="28"
                            Margin="0,6,6,6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{Binding ForegroundBrush}"
                            Content="✕"
                            Click="CloseWindow_Click" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="12"
                    Padding="0"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MinHeight="220">
                    <StackPanel Spacing="10" Margin="12">
                        <TextBlock Text="{Binding Strings.EntityPreviewDebugBabyFixesSection}"
                                   Foreground="{Binding ForegroundBrush}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Strings.EntityPreviewDebugBabyFixesDescription}"
                                   Foreground="{Binding ForegroundBrush}"
                                   Opacity="0.8"
                                   FontSize="12" />

                        <TextBlock Text="{Binding Strings.EntityPreviewDebugBaselineCompare}"
                                   Foreground="{Binding ForegroundBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0" />
                        <CheckBox Content="{Binding Strings.EntityPreviewDebugForceCpuSkinning}"
                                  IsChecked="{Binding ForceCpuSkinning, Mode=TwoWay}"
                                  ToolTip.Tip="{Binding Strings.EntityPreviewDebugForceCpuSkinningTooltip}" />
                        <CheckBox Content="{Binding Strings.EntityPreviewDebugLogDrawContract}"
                                  IsChecked="{Binding LogDrawContractEveryFrame, Mode=TwoWay}"
                                  ToolTip.Tip="{Binding Strings.EntityPreviewDebugLogDrawContractTooltip}" />
                        <CheckBox Content="{Binding Strings.EntityPreviewDebugLayerDebugFalseColor}"
                                  IsChecked="{Binding ShowDepthLayerDebug, Mode=TwoWay}"
                                  ToolTip.Tip="{Binding Strings.EntityPreviewDebugLayerDebugFalseColorTooltip}" />

                        <TextBlock Text="{Binding Strings.EntityPreviewDebugPartPoseCompose}"
                                   Foreground="{Binding ForegroundBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0" />
                        <WrapPanel ItemSpacing="8" LineSpacing="6">
                            <RadioButton Content="{Binding Strings.EntityPreviewDebugPartPoseErTimesT}"
                                         IsChecked="{Binding PartPoseErTimesT, Mode=TwoWay}"
                                         GroupName="EntityPartPose" />
                            <RadioButton Content="{Binding Strings.EntityPreviewDebugPartPoseLegacyTxEr}"
                                         IsChecked="{Binding PartPoseLegacyTxEr, Mode=TwoWay}"
                                         GroupName="EntityPartPose"
                                         ToolTip.Tip="{Binding Strings.EntityPreviewDebugPartPoseLegacyTxErTooltip}" />
                        </WrapPanel>

                        <TextBlock Text="{Binding Strings.EntityPreviewDebugLerFold}"
                                   Foreground="{Binding ForegroundBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0" />
                        <WrapPanel ItemSpacing="8" LineSpacing="6">
                            <RadioButton Content="{Binding Strings.EntityPreviewDebugLerPolicyDefault}"
                                         IsChecked="{Binding LerPolicyDefault, Mode=TwoWay}"
                                         GroupName="EntityLerBasis" />
                            <RadioButton Content="{Binding Strings.EntityPreviewDebugLerStandardWorldRoot}"
                                         IsChecked="{Binding LerStandardWorldRoot, Mode=TwoWay}"
                                         GroupName="EntityLerBasis" />
                            <RadioButton Content="{Binding Strings.EntityPreviewDebugLerRightComposeLocalChain}"
                                         IsChecked="{Binding LerRightComposeLocalChain, Mode=TwoWay}"
                                         GroupName="EntityLerBasis"
                                         ToolTip.Tip="{Binding Strings.EntityPreviewDebugLerRightComposeLocalChainTooltip}" />
                            <RadioButton Content="{Binding Strings.EntityPreviewDebugLerSkip}"
                                         IsChecked="{Binding LerSkip, Mode=TwoWay}"
                                         GroupName="EntityLerBasis" />
                        </WrapPanel>

                        <TextBlock Text="{Binding Strings.EntityPreviewDebugPartTreeRepair}"
                                   Foreground="{Binding ForegroundBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0" />
                        <CheckBox Content="{Binding Strings.EntityPreviewDebugSkipAllPartTreeRepair}"
                                  IsChecked="{Binding SkipAllPartTreeRepair, Mode=TwoWay}"
                                  ToolTip.Tip="{Binding Strings.EntityPreviewDebugSkipAllPartTreeRepairTooltip}" />

                        <TextBlock Text="{Binding Strings.EntityPreviewDebugIndividualRepairSteps}"
                                   Foreground="{Binding ForegroundBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding Strings.EntityPreviewDebugIndividualRepairStepsDescription}"
                                   Foreground="{Binding ForegroundBrush}"
                                   Opacity="0.8"
                                   FontSize="12" />
                        <CheckBox Content="{Binding Strings.EntityPreviewDebugRepairGlobalReparent}"
                                  IsChecked="{Binding RepairGlobalReparentRules, Mode=TwoWay}" />
                        <CheckBox Content="{Binding Strings.EntityPreviewDebugRepairQuadrupedLegReparent}"
                                  IsChecked="{Binding RepairQuadrupedLegReparent, Mode=TwoWay}"
                                  ToolTip.Tip="{Binding Strings.EntityPreviewDebugRepairQuadrupedLegReparentTooltip}" />
                        <CheckBox Content="{Binding Strings.EntityPreviewDebugRepairForceLegReparent}"
                                  IsChecked="{Binding RepairForceLegReparentOnFlatBake, Mode=TwoWay}"
                                  ToolTip.Tip="{Binding Strings.EntityPreviewDebugRepairForceLegReparentTooltip}" />
                        <CheckBox Content="{Binding Strings.EntityPreviewDebugRepairHeadStackLegReparent}"
                                  IsChecked="{Binding RepairHeadStackLegReparent, Mode=TwoWay}"
                                  ToolTip.Tip="{Binding Strings.EntityPreviewDebugRepairHeadStackLegReparentTooltip}" />
                        <CheckBox Content="{Binding Strings.EntityPreviewDebugRepairRemoveDuplicateRootSiblings}"
                                  IsChecked="{Binding RepairRemoveDuplicateRootSiblings, Mode=TwoWay}" />
                        <CheckBox Content="{Binding Strings.EntityPreviewDebugRepairCollapseInnerBody}"
                                  IsChecked="{Binding RepairCollapseInnerBody, Mode=TwoWay}" />
                        <CheckBox Content="{Binding Strings.EntityPreviewDebugRepairDeduplicateNestedPartIds}"
                                  IsChecked="{Binding RepairDeduplicateNestedPartIds, Mode=TwoWay}" />
                        <CheckBox Content="{Binding Strings.EntityPreviewDebugRepairZeroEquineRootOffset}"
                                  IsChecked="{Binding RepairZeroEquineRootOffset, Mode=TwoWay}"
                                  ToolTip.Tip="{Binding Strings.EntityPreviewDebugRepairZeroEquineRootOffsetTooltip}" />

                        <Border Margin="0,8,0,0"
                                Padding="8"
                                CornerRadius="4"
                                BorderBrush="{Binding CardBorderBrush}"
                                BorderThickness="1">
                            <TextBlock Text="{Binding Strings.EntityPreviewDebugSuggestedWorkflow}"
                                       Foreground="{Binding ForegroundBrush}"
                                       Opacity="0.8"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
