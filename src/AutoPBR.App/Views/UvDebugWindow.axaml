<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AutoPBR.App.ViewModels"
        xmlns:ctrls="using:AutoPBR.App.Controls"
        x:Class="AutoPBR.App.Views.UvDebugWindow"
        x:DataType="vm:UvDebugWindowViewModel"
        Width="760"
        Height="680"
        MinWidth="560"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="None">
    <Border Background="{Binding WindowBackground}"
            BorderBrush="{Binding CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="1">
        <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0"
                    Height="40"
                    Background="{Binding WindowBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="0,0,0,1"
                    PointerPressed="TitleBarDragRegion_PointerPressed">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding Strings.UvDebugTitle}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{Binding ForegroundBrush}" />
                    <Button Grid.Column="1"
                            Width="36"
                            Height="28"
                            Margin="0,6,6,6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{Binding ForegroundBrush}"
                            Content="✕"
                            Click="CloseWindow_Click" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="12"
                    Padding="0"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MinHeight="220">
                    <StackPanel Spacing="10" Margin="12">
                    <TextBlock Text="{Binding Strings.UvDebugGlobalControls}"
                               Foreground="{Binding ForegroundBrush}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Strings.UvDebugGlobalControlsDescription}"
                               Foreground="{Binding ForegroundBrush}"
                               Opacity="0.8"
                               FontSize="12" />

                    <Button Content="{Binding Strings.UvDebugResetOverrides}"
                            HorizontalAlignment="Left"
                            Click="ResetOverrides_Click" />

                    <CheckBox Content="{Binding Strings.UvDebugFlipU}"
                              IsChecked="{Binding FlipU, Mode=TwoWay}" />
                    <CheckBox Content="{Binding Strings.UvDebugFlipV}"
                              IsChecked="{Binding FlipV, Mode=TwoWay}" />

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Strings.UvDebugOffsetU}"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding ForegroundBrush}" />
                        <ctrls:OverlaySlider Width="120"
                                               Minimum="-128"
                                               Maximum="128"
                                               SmallChange="1"
                                               LargeChange="8"
                                               Increment="1"
                                               FormatString="0"
                                               Value="{Binding OffsetUPixels, Mode=TwoWay}" />

                        <TextBlock Text="{Binding Strings.UvDebugOffsetV}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   Foreground="{Binding ForegroundBrush}" />
                        <ctrls:OverlaySlider Width="120"
                                               Minimum="-128"
                                               Maximum="128"
                                               SmallChange="1"
                                               LargeChange="8"
                                               Increment="1"
                                               FormatString="0"
                                               Value="{Binding OffsetVPixels, Mode=TwoWay}" />
                    </StackPanel>

                    <TextBlock Text="{Binding Strings.UvDebugFaceSemanticRouting}"
                               Foreground="{Binding ForegroundBrush}"
                               FontWeight="SemiBold"
                               Margin="0,8,0,0" />
                    <CheckBox Content="{Binding Strings.UvDebugSwapNorthSouth}"
                              IsChecked="{Binding SwapFaceNorthSouth, Mode=TwoWay}" />
                    <CheckBox Content="{Binding Strings.UvDebugSwapEastWest}"
                              IsChecked="{Binding SwapFaceEastWest, Mode=TwoWay}" />
                    <CheckBox Content="{Binding Strings.UvDebugSwapUpDown}"
                              IsChecked="{Binding SwapFaceUpDown, Mode=TwoWay}" />

                    <TextBlock Text="{Binding Strings.UvDebugBakerConversion}"
                               Foreground="{Binding ForegroundBrush}"
                               FontWeight="SemiBold"
                               Margin="0,8,0,0" />
                    <CheckBox Content="{Binding Strings.UvDebugPreserveDirectionalBounds}"
                              IsChecked="{Binding PreserveDirectionalBounds, Mode=TwoWay}" />
                    <CheckBox Content="{Binding Strings.UvDebugUseBottomLeftUvOrigin}"
                              IsChecked="{Binding UseBottomLeftUvOrigin, Mode=TwoWay}" />

                    <TextBlock Text="{Binding Strings.UvDebugFaceCornerOrdering}"
                               Foreground="{Binding ForegroundBrush}"
                               FontWeight="SemiBold"
                               Margin="0,8,0,0" />
                    <WrapPanel ItemSpacing="8" LineSpacing="6">
                        <RadioButton Content="{Binding Strings.UvDebugCornerOrderDefault}" IsChecked="{Binding CornerOrderDefault, Mode=TwoWay}" GroupName="UvCornerOrder" />
                        <RadioButton Content="{Binding Strings.UvDebugCornerOrderRotate90}" IsChecked="{Binding CornerOrderRotate90, Mode=TwoWay}" GroupName="UvCornerOrder" />
                        <RadioButton Content="{Binding Strings.UvDebugCornerOrderRotate180}" IsChecked="{Binding CornerOrderRotate180, Mode=TwoWay}" GroupName="UvCornerOrder" />
                        <RadioButton Content="{Binding Strings.UvDebugCornerOrderRotate270}" IsChecked="{Binding CornerOrderRotate270, Mode=TwoWay}" GroupName="UvCornerOrder" />
                        <RadioButton Content="{Binding Strings.UvDebugCornerOrderReverseWinding}" IsChecked="{Binding CornerOrderReverseWinding, Mode=TwoWay}" GroupName="UvCornerOrder" />
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Strings.UvDebugGlobalFaceRotation}"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding ForegroundBrush}" />
                        <RadioButton Content="{Binding Strings.UvDebugRotation0}" IsChecked="{Binding Rotation0, Mode=TwoWay}" GroupName="UvRotation" />
                        <RadioButton Content="{Binding Strings.UvDebugRotation90}" IsChecked="{Binding Rotation90, Mode=TwoWay}" GroupName="UvRotation" />
                        <RadioButton Content="{Binding Strings.UvDebugRotation180}" IsChecked="{Binding Rotation180, Mode=TwoWay}" GroupName="UvRotation" />
                        <RadioButton Content="{Binding Strings.UvDebugRotation270}" IsChecked="{Binding Rotation270, Mode=TwoWay}" GroupName="UvRotation" />
                    </StackPanel>

                    <Border Margin="0,8,0,0"
                            Padding="8"
                            CornerRadius="4"
                            BorderBrush="{Binding CardBorderBrush}"
                            BorderThickness="1">
                        <TextBlock Text="{Binding Strings.UvDebugLiveChangesHint}"
                                   Foreground="{Binding ForegroundBrush}"
                                   Opacity="0.8"
                                   FontSize="12" />
                    </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
