<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AutoPBR.App.ViewModels"
        xmlns:m="using:AutoPBR.App.Models"
        xmlns:ctrls="using:AutoPBR.App.Controls"
        xmlns:core="using:AutoPBR.Core.Models"
        xmlns:conv="using:AutoPBR.App.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AutoPBR.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/AutoPBR-logo.ico"
        Title="{Binding Strings.AppTitle}"
        Width="1000"
        Height="720"
        SystemDecorations="None"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="None">

    <Window.Resources>
        <conv:NullableFloatStringConverter x:Key="NullableFloatStr" />
    </Window.Resources>

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <Border x:Name="RootBorder"
                Background="{Binding WindowBackground}"
                BorderBrush="{Binding CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="1">
        <Grid RowDefinitions="Auto,*,Auto" Background="{Binding WindowBackground}">
        <!-- Custom title bar: logo (left), title (center), window controls (right); flush with content -->
        <Border Grid.Row="0"
                Background="{Binding WindowBackground}"
                Height="40">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Border x:Name="TitleBarDragRegion"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Background="Transparent"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        PointerPressed="TitleBarDragRegion_PointerPressed">
                    <Grid ColumnDefinitions="Auto,*">
                        <Image Grid.Column="0"
                               Source="/Assets/AutoPBR-logo.png"
                               Width="24"
                               Height="24"
                               Margin="12,0,12,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False" />
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="{Binding Strings.AppTitle}"
                                   Foreground="{Binding ForegroundBrush}"
                                   IsHitTestVisible="False" />
                    </Grid>
                </Border>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0">
                    <Button x:Name="MinimizeButton"
                            Width="46" Height="40"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="Minimize"
                            Click="WindowMinimize_Click">
                        <TextBlock Text="&#x2014;" FontSize="14" Foreground="{Binding ForegroundBrush}" />
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Width="46" Height="40"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="Maximize"
                            Click="WindowMaximize_Click">
                        <TextBlock Text="&#x25A1;" FontSize="12" Foreground="{Binding ForegroundBrush}" />
                    </Button>
                    <Button x:Name="CloseButton"
                            Width="46" Height="40"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="Close"
                            Click="WindowClose_Click">
                        <TextBlock Text="&#x2715;" FontSize="12" Foreground="{Binding ForegroundBrush}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ContentGrid" Grid.Row="1" Background="{Binding WindowBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="280" MinWidth="260" MaxWidth="600" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <ScrollViewer x:Name="MainScrollViewer">
            <TabControl x:Name="MainTabControl" Margin="16">
                <TabItem Header="{Binding Strings.TabScan}">
                    <StackPanel Margin="0,12,0,0" Spacing="16">
                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.Input}" />
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                    <TextBox Grid.Column="0" Watermark="{Binding Strings.ResourcePackWatermark}" Text="{Binding PackPath, Mode=TwoWay}" />
                                    <Button Grid.Column="1" Content="{Binding Strings.ScanButton}" Command="{Binding ScanArchiveCommand}" />
                                    <Button Grid.Column="2" Content="{Binding Strings.Browse}" Click="BrowsePack_Click" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.BatchConversion}" />
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                    <TextBox Grid.Column="0" Watermark="{Binding Strings.BatchFolderWatermark}" Text="{Binding BatchFolderPath, Mode=TwoWay}" />
                                    <Button Grid.Column="1" Content="{Binding Strings.ScanButton}" Command="{Binding ScanBatchCommand}" />
                                    <Button Grid.Column="2" Content="{Binding Strings.Convert}" Command="{Binding BatchConvertCommand}" />
                                    <Button Grid.Column="3" Content="{Binding Strings.Browse}" Click="BrowseBatchFolder_Click" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.Log}" />
                                    <Button DockPanel.Dock="Right"
                                            Content="{Binding Strings.OpenLogFolder}"
                                            Margin="8,0,0,0"
                                            Padding="8,2"
                                            Click="OpenLogFolder_Click" />
                                </DockPanel>
                                <Border CornerRadius="6" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="8">
                                    <ScrollViewer Height="200" Name="LogScrollViewer">
                                        <ItemsControl ItemsSource="{Binding LogLines}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding}"
                                                             FontFamily="Consolas"
                                                             FontSize="12"
                                                             IsReadOnly="True"
                                                             BorderThickness="0"
                                                             Background="Transparent"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>

                <TabItem Header="{Binding Strings.TabExplore}">
                    <StackPanel Margin="0,12,0,0" Spacing="16">
                        <!-- Texture types: syncs with folder checkboxes in the tree when a pack is scanned -->
                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.TextureTypes}" />
                                <WrapPanel Orientation="Horizontal" ItemSpacing="16" LineSpacing="8">
                                    <CheckBox Content="{Binding Strings.Blocks}" IsChecked="{Binding ProcessBlocks, Mode=TwoWay}"
                                        ToolTip.Tip="{Binding Strings.BlocksTooltip}" />
                                    <CheckBox Content="{Binding Strings.Items}" IsChecked="{Binding ProcessItems, Mode=TwoWay}"
                                        ToolTip.Tip="{Binding Strings.ItemsTooltip}" />
                                    <CheckBox Content="{Binding Strings.Armor}" IsChecked="{Binding ProcessArmor, Mode=TwoWay}"
                                        ToolTip.Tip="{Binding Strings.ArmorTooltip}" />
                                    <CheckBox Content="{Binding Strings.Entity}" IsChecked="{Binding ProcessEntity, Mode=TwoWay}"
                                        ToolTip.Tip="{Binding Strings.EntityTooltip}" />
                                    <CheckBox IsChecked="{Binding ProcessParticles, Mode=TwoWay}" MaxWidth="200"
                                        ToolTip.Tip="{Binding Strings.ParticlesTooltip}">
                                        <TextBlock Text="{Binding Strings.Particles}" TextWrapping="Wrap" />
                                    </CheckBox>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.ResourceExplorer}" />
                                <TextBlock Text="{Binding Strings.ExploreEmptyMessage}" IsVisible="{Binding ShowExploreEmptyMessage}"
                                    TextWrapping="Wrap" Opacity="0.8" Margin="0,8,0,0" />
                                <StackPanel x:Name="ExplorePanel" IsVisible="{Binding HasScannedArchive}" Margin="0,8,0,0" Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBox Watermark="{Binding Strings.FilterWatermark}" Text="{Binding ExploreFilter, Mode=TwoWay}" MinWidth="180" />
                                        <TextBlock Text="{Binding Strings.ExploreTagFilter}" VerticalAlignment="Center" />
                                        <ComboBox ItemsSource="{Binding ExploreTagFilterOptions}"
                                                  SelectedValue="{Binding ExploreTagFilterId, Mode=TwoWay}"
                                                  SelectedValueBinding="{Binding Id}"
                                                  MinWidth="120"
                                                  PlaceholderText="{Binding Strings.ExploreTagFilterAll}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="m:ExploreTagFilterOption">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="{Binding Strings.ExploreBack}" Command="{Binding GoBackExploreCommand}"
                                            IsEnabled="{Binding CanGoBackExplore}" />
                                        <ItemsControl ItemsSource="{Binding ExploreBreadcrumb}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="4" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="m:ArchiveNode">
                                                    <Button Content="{Binding Name}"
                                                            Command="{Binding #ExplorePanel.((vm:MainWindowViewModel)DataContext).GoToBreadcrumbCommand, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                            CommandParameter="{Binding}" Padding="4,2" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Content="{Binding Strings.ExploreExpandAll}" Command="{Binding ExploreExpandAllCommand}" />
                                        <Button Content="{Binding Strings.ExploreCollapseAll}" Command="{Binding ExploreCollapseAllCommand}" />
                                        <Button Content="{Binding Strings.ClearTagOverrides}" Command="{Binding ClearTagOverridesCommand}"
                                                IsVisible="{Binding HasScannedArchive}"
                                                ToolTip.Tip="{Binding Strings.ClearTagOverridesTooltip}" />
                                    </StackPanel>
                                    <!-- Tag legend -->
                                    <ItemsControl ItemsSource="{Binding TagLegendItems}" Margin="0,6,0,0" IsVisible="{Binding HasScannedArchive}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="12" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="m:TagLegendItem">
                                                <TextBlock FontSize="11" Opacity="0.85">
                                                    <Run FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                    <Run Text=": " />
                                                    <Run Text="{Binding Description}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TreeView ItemsSource="{Binding ExploreViewItems}"
                                              x:Name="ExploreTreeView"
                                              SelectedItem="{Binding SelectedExploreNode, Mode=TwoWay}">
                                        <TreeView.Styles>
                                            <Style Selector="TreeViewItem">
                                                <Setter Property="IsExpanded"
                                                        Value="{Binding $self.((m:ArchiveNode)DataContext).IsExpanded, Mode=TwoWay, FallbackValue=False, TargetNullValue=False}" />
                                                <Setter Property="IsVisible">
                                                    <Setter.Value>
                                                        <Binding Path="$self.((m:ArchiveNode)DataContext).IsVisibleByFilter"
                                                                 FallbackValue="True"
                                                                 TargetNullValue="True" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                            <!-- Show "Set as Preview" button only when pointer is over the row (Border) -->
                                            <Style Selector="Border.preview-row-host Button.preview-btn">
                                                <Setter Property="Opacity" Value="0" />
                                                <Setter Property="IsHitTestVisible" Value="False" />
                                            </Style>
                                            <Style Selector="Border.preview-row-host:pointerover Button.preview-btn">
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="IsHitTestVisible" Value="True" />
                                            </Style>
                                        </TreeView.Styles>
                                        <TreeView.DataTemplates>
                                            <TreeDataTemplate DataType="m:ArchiveNode" ItemsSource="{Binding Children}">
                                                <Border Classes="preview-row-host" Background="Transparent" Padding="0">
                                                    <Border.ContextMenu>
                                                        <ContextMenu IsVisible="{Binding !IsFolder}" ItemsSource="{Binding TagMenuEntries}">
                                                            <ContextMenu.ItemTemplate>
                                                                <DataTemplate x:DataType="m:TagMenuEntry">
                                                                    <MenuItem Header="{Binding MenuHeader}"
                                                                              Command="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).ExecuteTagMenuCommand, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                              CommandParameter="{Binding}" />
                                                                </DataTemplate>
                                                            </ContextMenu.ItemTemplate>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                                            <CheckBox IsChecked="{Binding ManualOverride, Mode=TwoWay}" IsThreeState="True"
                                                                ToolTip.Tip="Checked = include, Unchecked = exclude, Indeterminate = use other rules" />
                                                            <Grid IsVisible="{Binding IsBatchPackRoot}" Width="16" Height="16">
                                                                <Image Source="{Binding PackIcon}" Width="16" Height="16"
                                                                       IsVisible="{Binding HasPackIcon}"
                                                                       VerticalAlignment="Center" />
                                                                <Image Source="avares://AutoPBR.App/Assets/AutoPBR-logo.png" Width="16" Height="16"
                                                                       IsVisible="{Binding !HasPackIcon}"
                                                                       VerticalAlignment="Center" />
                                                            </Grid>
                                                            <Button Command="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).EnterFolderCommand, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                    CommandParameter="{Binding}" IsVisible="{Binding IsFolder}" Padding="2,0">
                                                                <ctrls:MinecraftFormattedTextBlock FormattedText="{Binding Name}" VerticalAlignment="Center" />
                                                            </Button>
                                                            <ctrls:MinecraftFormattedTextBlock FormattedText="{Binding Name}" VerticalAlignment="Center" IsVisible="{Binding !IsFolder}" />
                                                            <Button Classes="preview-btn"
                                                                    Content="Set as Preview"
                                                                    Command="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).SetPreviewTextureCommand, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                    CommandParameter="{Binding}"
                                                                    IsVisible="{Binding !IsFolder}"
                                                                    Padding="4,2" />
                                                        </StackPanel>
                                                        <ItemsControl Grid.Column="2" ItemsSource="{Binding DisplayTags}" IsVisible="{Binding !IsFolder}"
                                                                     VerticalAlignment="Center" HorizontalAlignment="Right">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" Spacing="4" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="m:DisplayTagItem">
                                                                    <Border Background="#40FFFFFF" CornerRadius="4" Padding="6,2">
                                                                        <TextBlock Text="{Binding DisplayName}" FontSize="11" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </Border>
                                            </TreeDataTemplate>
                                        </TreeView.DataTemplates>
                                    </TreeView>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>

                <TabItem Header="{Binding Strings.TabTune}">
                    <StackPanel Margin="0,12,0,0" Spacing="16">
                        <!-- Quality profile -->
                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.QualityProfile}" />
                                <ComboBox Width="220"
                                          ItemsSource="{Binding QualityProfileOptions}"
                                          SelectedItem="{Binding SelectedQualityProfile, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:FoliageModeOption">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Normals -->
                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.TuneNormals}" />
                                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.NormalStrength}"
                                               ToolTip.Tip="{Binding Strings.NormalStrengthTooltip}" />
                                    <Slider Grid.Row="0" Grid.Column="1" Minimum="0.1" Maximum="8" SmallChange="0.01" LargeChange="0.1"
                                            Value="{Binding NormalIntensity, Mode=TwoWay}"
                                            ToolTip.Tip="{Binding Strings.NormalStrengthTooltip}" />
                                    <TextBox Grid.Row="0" Grid.Column="2"
                                             Width="70"
                                             VerticalAlignment="Center"
                                             HorizontalContentAlignment="Right"
                                             Text="{Binding NormalIntensity, Mode=TwoWay, StringFormat={}{0:0.###}, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.NormalOperatorLabel}" />
                                    <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Width="220"
                                              ItemsSource="{Binding NormalOperatorOptions}"
                                              SelectedItem="{Binding SelectedNormalOperator, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:FoliageModeOption">
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.NormalKernelSizeLabel}" />
                                    <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Width="220"
                                              ItemsSource="{Binding NormalKernelSizeOptions}"
                                              SelectedItem="{Binding SelectedNormalKernelSize, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:FoliageModeOption">
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Derivative}" />
                                    <ComboBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Width="220"
                                              ItemsSource="{Binding NormalDerivativeOptions}"
                                              SelectedItem="{Binding SelectedNormalDerivative, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:FoliageModeOption">
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                                <CheckBox IsChecked="{Binding UseDeepBumpNormals, Mode=TwoWay}" MaxWidth="320"
                                    ToolTip.Tip="{Binding Strings.NormalsFromDeepBumpTooltip}">
                                    <TextBlock Text="{Binding Strings.NormalsFromDeepBump}" TextWrapping="Wrap" />
                                </CheckBox>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,0" IsVisible="{Binding UseDeepBumpNormals}">
                                    <TextBlock Text="{Binding Strings.DeepBumpOverlap}" VerticalAlignment="Center"
                                        ToolTip.Tip="{Binding Strings.DeepBumpOverlapTooltip}" />
                                    <ComboBox Width="120" ItemsSource="{Binding DeepBumpOverlapOptions}"
                                        SelectedItem="{Binding SelectedDeepBumpOverlap, Mode=TwoWay}"
                                        ToolTip.Tip="{Binding Strings.DeepBumpOverlapTooltip}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Normals Advanced -->
                                <Border Margin="0,14,0,0" Padding="0,14,0,0" BorderBrush="{Binding CardBorderBrush}" BorderThickness="0,1,0,0">
                                    <StackPanel Spacing="14">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Strings.Advanced}" />
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Strings.Preprocessing}" />
                                        <CheckBox IsChecked="{Binding PreprocessLinearize, Mode=TwoWay}">
                                            <TextBlock Text="{Binding Strings.PreprocessLinearize}" TextWrapping="Wrap" />
                                        </CheckBox>
                                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.PreprocessDenoiseRadius}" />
                                            <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="6" SmallChange="1" LargeChange="1"
                                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                                    Value="{Binding PreprocessDenoiseRadius, Mode=TwoWay}" />
                                            <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"
                                                       Text="{Binding PreprocessDenoiseRadius}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.PreprocessDenoiseBlend}" />
                                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                                                    Value="{Binding PreprocessDenoiseBlend, Mode=TwoWay}" />
                                            <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"
                                                       Text="{Binding PreprocessDenoiseBlend, StringFormat={}{0:0.##}}" />
                                        </Grid>
                                        <CheckBox IsChecked="{Binding PreprocessFrequencySplit, Mode=TwoWay}">
                                            <TextBlock Text="{Binding Strings.PreprocessFrequencySplit}" TextWrapping="Wrap" />
                                        </CheckBox>
                                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10"
                                              IsVisible="{Binding PreprocessFrequencySplit}">
                                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.PreprocessFrequencyRadius}" />
                                            <Slider Grid.Row="0" Grid.Column="1" Minimum="1" Maximum="12" SmallChange="1" LargeChange="1"
                                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                                    Value="{Binding PreprocessFrequencyRadius, Mode=TwoWay}" />
                                            <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"
                                                       Text="{Binding PreprocessFrequencyRadius}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.PreprocessFrequencyDetailStrength}" />
                                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="2" SmallChange="0.05" LargeChange="0.1"
                                                    Value="{Binding PreprocessFrequencyDetailStrength, Mode=TwoWay}" />
                                            <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"
                                                       Text="{Binding PreprocessFrequencyDetailStrength, StringFormat={}{0:0.##}}" />
                                        </Grid>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Strings.DeepBumpAdvanced}" IsVisible="{Binding UseDeepBumpNormals}" />
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" IsVisible="{Binding UseDeepBumpNormals}">
                                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.DeepBumpInputMode}" />
                                            <ComboBox Grid.Row="0" Grid.Column="1" Width="220"
                                                      ItemsSource="{Binding DeepBumpInputModeOptions}"
                                                      SelectedItem="{Binding SelectedDeepBumpInputMode, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:FoliageModeOption">
                                                        <TextBlock Text="{Binding DisplayName}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                      IsChecked="{Binding DeepBumpForceBlue255, Mode=TwoWay}">
                                                <TextBlock Text="{Binding Strings.DeepBumpForceBlue255}" TextWrapping="Wrap" />
                                            </CheckBox>
                                        </Grid>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Strings.AoAdvanced}" />
                                        <CheckBox IsChecked="{Binding GenerateAo, Mode=TwoWay}">
                                            <TextBlock Text="{Binding Strings.GenerateAo}" TextWrapping="Wrap" />
                                        </CheckBox>
                                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10"
                                              IsVisible="{Binding GenerateAo}">
                                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.AoRadius}" />
                                            <Slider Grid.Row="0" Grid.Column="1" Minimum="1" Maximum="24" SmallChange="1" LargeChange="1"
                                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                                    Value="{Binding AoRadius, Mode=TwoWay}" />
                                            <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"
                                                       Text="{Binding AoRadius}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.AoStrength}" />
                                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="3" SmallChange="0.05" LargeChange="0.1"
                                                    Value="{Binding AoStrength, Mode=TwoWay}" />
                                            <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"
                                                       Text="{Binding AoStrength, StringFormat={}{0:0.##}}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Specular -->
                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.TuneSpecular}" />
                                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.SmoothnessScale}"
                                               ToolTip.Tip="{Binding Strings.SmoothnessScaleTooltip}" />
                                    <Slider Grid.Row="0" Grid.Column="1" Minimum="0.2" Maximum="3" SmallChange="0.05" LargeChange="0.1"
                                            Value="{Binding SmoothnessScale, Mode=TwoWay}"
                                            ToolTip.Tip="{Binding Strings.SmoothnessScaleTooltip}" />
                                    <TextBox Grid.Row="0" Grid.Column="2"
                                             Width="70"
                                             VerticalAlignment="Center"
                                             HorizontalContentAlignment="Right"
                                             Text="{Binding SmoothnessScale, Mode=TwoWay, StringFormat={}{0:0.###}, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MetallicBoost}"
                                               ToolTip.Tip="{Binding Strings.MetallicBoostTooltip}" />
                                    <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="3" SmallChange="0.05" LargeChange="0.1"
                                            Value="{Binding MetallicBoost, Mode=TwoWay}"
                                            ToolTip.Tip="{Binding Strings.MetallicBoostTooltip}" />
                                    <TextBox Grid.Row="1" Grid.Column="2"
                                             Width="70"
                                             VerticalAlignment="Center"
                                             HorizontalContentAlignment="Right"
                                             Text="{Binding MetallicBoost, Mode=TwoWay, StringFormat={}{0:0.###}, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.PorosityBias}"
                                               ToolTip.Tip="{Binding Strings.PorosityBiasTooltip}" />
                                    <Slider Grid.Row="2" Grid.Column="1" Minimum="-128" Maximum="128" SmallChange="1" LargeChange="8"
                                            Value="{Binding PorosityBias, Mode=TwoWay}"
                                            ToolTip.Tip="{Binding Strings.PorosityBiasTooltip}" />
                                    <TextBox Grid.Row="2" Grid.Column="2"
                                             Width="70"
                                             VerticalAlignment="Center"
                                             HorizontalContentAlignment="Right"
                                             Text="{Binding PorosityBias, Mode=TwoWay, StringFormat={}{0:0.###}, UpdateSourceTrigger=PropertyChanged}" />

                                    <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" IsChecked="{Binding FastSpecular, Mode=TwoWay}" MaxWidth="280"
                                        ToolTip.Tip="{Binding Strings.FastSpecularTooltip}">
                                        <TextBlock Text="{Binding Strings.FastSpecular}" TextWrapping="Wrap" />
                                    </CheckBox>
                                </Grid>

                                <!-- Specular Advanced -->
                                <Border Margin="0,14,0,0" Padding="0,14,0,0" BorderBrush="{Binding CardBorderBrush}" BorderThickness="0,1,0,0">
                                    <StackPanel Spacing="14">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Strings.Advanced}" />
                                        <CheckBox IsChecked="{Binding SpecularUsePercentileRemap, Mode=TwoWay}">
                                            <TextBlock Text="{Binding Strings.SpecularPercentileRemap}" TextWrapping="Wrap" />
                                        </CheckBox>
                                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10"
                                              IsVisible="{Binding SpecularUsePercentileRemap}">
                                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.SpecularRemapLowPercentile}" />
                                            <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="0.5" SmallChange="0.01" LargeChange="0.05"
                                                    Value="{Binding SpecularRemapLowPercentile, Mode=TwoWay}" />
                                            <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"
                                                       Text="{Binding SpecularRemapLowPercentile, StringFormat={}{0:0.##}}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.SpecularRemapHighPercentile}" />
                                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0.5" Maximum="1" SmallChange="0.01" LargeChange="0.05"
                                                    Value="{Binding SpecularRemapHighPercentile, Mode=TwoWay}" />
                                            <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"
                                                       Text="{Binding SpecularRemapHighPercentile, StringFormat={}{0:0.##}}" />
                                        </Grid>
                                        <TextBlock Text="{Binding Strings.MetalHeuristicSubstrings}" />
                                        <TextBox Watermark="{Binding Strings.MetalHeuristicSubstringsWatermark}"
                                                 Text="{Binding MetalHeuristicSubstrings, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Height -->
                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.TuneHeight}" />
                                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.HeightStrength}"
                                               ToolTip.Tip="{Binding Strings.HeightStrengthTooltip}" />
                                    <Slider Grid.Row="0" Grid.Column="1" Minimum="0.001" Maximum="2" SmallChange="0.001" LargeChange="0.01"
                                            Value="{Binding HeightIntensity, Mode=TwoWay}"
                                            ToolTip.Tip="{Binding Strings.HeightStrengthTooltip}" />
                                    <TextBox Grid.Row="0" Grid.Column="2"
                                             Width="70"
                                             VerticalAlignment="Center"
                                             HorizontalContentAlignment="Right"
                                             Text="{Binding HeightIntensity, Mode=TwoWay, StringFormat={}{0:0.###}, UpdateSourceTrigger=PropertyChanged}" />

                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="16">
                                        <TextBlock VerticalAlignment="Center" Text="{Binding Strings.Foliage}"
                                                   ToolTip.Tip="{Binding Strings.FoliageTooltip}" />
                                        <ComboBox Width="140" ItemsSource="{Binding FoliageModeOptions}"
                                            SelectedItem="{Binding SelectedFoliageMode, Mode=TwoWay}"
                                            ToolTip.Tip="{Binding Strings.FoliageTooltip}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:FoliageModeOption">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <!-- Height Advanced -->
                                <Border Margin="0,14,0,0" Padding="0,14,0,0" BorderBrush="{Binding CardBorderBrush}" BorderThickness="0,1,0,0">
                                    <StackPanel Spacing="14">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Strings.Advanced}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Tag rules (custom) -->
                        <Border x:Name="TagRulesCard" CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.TagRules}" />
                                <TextBlock Text="{Binding Strings.TagRulesCustomDescription}" TextWrapping="Wrap" Opacity="0.9" />
                                <ItemsControl x:Name="CustomTagRulesList" ItemsSource="{Binding CustomTagRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="core:CustomTagRuleEntry">
                                            <Border Margin="0,0,0,8" Padding="8" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="4">
                                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="6" ColumnSpacing="8">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleId, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="0" Grid.Column="1" Watermark="e.g. mytag"
                                                             Text="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleDisplayName, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="1" Grid.Column="1" Watermark="e.g. My Tag"
                                                             Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleKeywords, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="2" Grid.Column="1" Watermark="e.g. stone, rock"
                                                             Text="{Binding Keywords, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleNormalIntensityOpt, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" VerticalAlignment="Center"
                                                               ToolTip.Tip="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleIntensityTooltip, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                    <TextBox Grid.Row="3" Grid.Column="1" Watermark="—"
                                                             Text="{Binding NormalIntensity, Mode=TwoWay, Converter={StaticResource NullableFloatStr}, UpdateSourceTrigger=LostFocus}" />
                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleHeightIntensityOpt, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" VerticalAlignment="Center"
                                                               ToolTip.Tip="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleIntensityTooltip, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                    <TextBox Grid.Row="4" Grid.Column="1" Watermark="—"
                                                             Text="{Binding HeightIntensity, Mode=TwoWay, Converter={StaticResource NullableFloatStr}, UpdateSourceTrigger=LostFocus}" />
                                                    <WrapPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,0">
                                                        <CheckBox Margin="0,0,12,6" Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleEnabled, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" IsChecked="{Binding Enabled, Mode=TwoWay}" ToolTip.Tip="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleEnabledTooltip, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                        <CheckBox Margin="0,0,12,6" Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.InvertHeight, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" IsChecked="{Binding InvertHeight, Mode=TwoWay}" />
                                                        <CheckBox Margin="0,0,12,6" Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.InvertSpecular, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" IsChecked="{Binding InvertSpecular, Mode=TwoWay}" />
                                                        <CheckBox Margin="0,0,12,6" Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleInvertNormalX, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" IsChecked="{Binding InvertNormalRed, Mode=TwoWay}" />
                                                        <CheckBox Margin="0,0,12,6" Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleInvertNormalY, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" IsChecked="{Binding InvertNormalGreen, Mode=TwoWay}" />
                                                        <Button Margin="0,0,4,6" Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleMoveUp, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                Command="{Binding ((vm:MainWindowViewModel)DataContext).MoveCustomTagRuleUpCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                CommandParameter="{Binding}" Padding="6,4" ToolTip.Tip="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleMoveUpTooltip, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                        <Button Margin="0,0,4,6" Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleMoveDown, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                Command="{Binding ((vm:MainWindowViewModel)DataContext).MoveCustomTagRuleDownCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                CommandParameter="{Binding}" Padding="6,4" ToolTip.Tip="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleMoveDownTooltip, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                        <Button Margin="0,0,0,6" Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RemoveTagRule, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                Command="{Binding ((vm:MainWindowViewModel)DataContext).RemoveCustomTagRuleCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                CommandParameter="{Binding}" Padding="8,4" />
                                                    </WrapPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="{Binding Strings.AddCustomTagRule}" Command="{Binding AddCustomTagRuleCommand}" Padding="8,4" />
                                    <Button Content="{Binding Strings.RefreshTagRules}" Command="{Binding RefreshTagRulesCommand}" Padding="8,4"
                                            ToolTip.Tip="{Binding Strings.RefreshTagRulesTooltip}" />
                                    <Button Content="{Binding Strings.ExportTagRules}" Click="ExportTagRules_Click" Padding="8,4"
                                            ToolTip.Tip="{Binding Strings.ExportTagRulesTooltip}" />
                                    <Button Content="{Binding Strings.ImportTagRules}" Click="ImportTagRules_Click" Padding="8,4"
                                            ToolTip.Tip="{Binding Strings.ImportTagRulesTooltip}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </TabItem>

                <TabItem Header="{Binding Strings.TabSettings}">
                    <StackPanel Margin="0,12,0,0" Spacing="16">
                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.Output}" />
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                                    <TextBox Grid.Row="0" Grid.Column="0" Watermark="{Binding Strings.OutputFolderWatermark}" Text="{Binding OutputDirectory, Mode=TwoWay}" />
                                    <Button Grid.Row="0" Grid.Column="1" Content="{Binding Strings.Browse}" Click="BrowseOutput_Click" />

                                    <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" IsReadOnly="True" Watermark="{Binding Strings.OutputPathWatermark}" Text="{Binding OutputZipPath}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.Engine}" />

                                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MaxThreads}"
                                               ToolTip.Tip="{Binding Strings.MaxThreadsTooltip}" />
                                    <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="{Binding MaxThreadsMax}" SmallChange="1" LargeChange="1"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            Value="{Binding MaxThreads, Mode=TwoWay}"
                                            ToolTip.Tip="{Binding Strings.MaxThreadsTooltip}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"
                                               Text="{Binding MaxThreads, StringFormat={}{0:0}}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.TempFolder}"
                                               ToolTip.Tip="{Binding Strings.TempFolderTooltip}" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,2,0,0"
                                             Watermark="{Binding Strings.TempFolderWatermark}"
                                             Text="{Binding TempDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip.Tip="{Binding Strings.TempFolderTooltip}" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text=" " />
                                </Grid>

                                <CheckBox IsChecked="{Binding UseLegacyExtractor, Mode=TwoWay}" MaxWidth="280"
                                    ToolTip.Tip="{Binding Strings.UseLegacyExtractorTooltip}">
                                    <TextBlock Text="{Binding Strings.UseLegacyExtractor}" TextWrapping="Wrap" />
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.Appearance}" />
                                <WrapPanel Orientation="Horizontal" ItemSpacing="16" LineSpacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock VerticalAlignment="Center" Text="{Binding Strings.ColorScheme}"
                                                   ToolTip.Tip="{Binding Strings.UiThemeTooltip}" />
                                        <ComboBox Width="220" ItemsSource="{Binding ColorSchemeOptions}"
                                            SelectedItem="{Binding SelectedColorSchemeOption, Mode=TwoWay}"
                                            ToolTip.Tip="{Binding Strings.UiThemeTooltip}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:FoliageModeOption">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock VerticalAlignment="Center" Text="{Binding Strings.Language}"
                                                   ToolTip.Tip="{Binding Strings.UiLanguageTooltip}" />
                                        <ComboBox Width="160" ItemsSource="{Binding SupportedLanguages}"
                                            SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                            ToolTip.Tip="{Binding Strings.UiLanguageTooltip}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:LanguageOption">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>
            </TabControl>
                </ScrollViewer>

                <Button x:Name="JumpToTopButton"
                        Width="42" Height="42"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,18"
                        Opacity="0"
                        IsVisible="False"
                        IsHitTestVisible="False"
                        Background="#00000000"
                        BorderThickness="0"
                        Click="JumpToTopButton_Click">
                    <TextBlock Text="↑" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
            </Grid>

            <!-- Draggable splitter: 8px hit area; 1px line drawn on top (no nested Grid so splitter sees main Grid) -->
            <GridSplitter Grid.Column="1"
                          Background="Transparent"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="LeftSide"
                          HorizontalAlignment="Stretch" />
            <Border Grid.Column="1" Width="1" HorizontalAlignment="Right" Background="{Binding CardBorderBrush}"
                    IsHitTestVisible="False" />

            <!-- Preview panel: right column, visible on all tabs; render view in main area with gradient fade top/bottom, no border top/bottom -->
            <Border Grid.Column="2"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="1,0,0,0"
                    Padding="12">
                <Grid RowDefinitions="Auto,*" RowSpacing="8">
                    <StackPanel Orientation="Vertical" Spacing="4">
                        <TextBlock Text="Preview" FontWeight="SemiBold" Foreground="{Binding ForegroundBrush}" />
                        <TextBlock Text="{Binding PreviewTextureName}"
                                   Foreground="{Binding ForegroundBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   Opacity="0.9" />
                    </StackPanel>
                    <Grid Grid.Row="1" ClipToBounds="True">
                        <Image Source="{Binding PreviewImage}" Stretch="Uniform" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{Binding WindowBackground}" Padding="12">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                    <Button Content="{Binding Strings.Cancel}" Command="{Binding CancelCommand}" IsEnabled="{Binding IsConverting}" />
                    <Button Content="{Binding Strings.Convert}" Command="{Binding ConvertCommand}" />
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                    <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Margin="0,0,0,4" />
                    <ProgressBar Minimum="0" Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}" Height="16" Foreground="{Binding AccentBrush}" />
                </StackPanel>
            </DockPanel>
        </Border>
        </Grid>
    </Border>
        <!-- Resize grips (drawn on top); left, right, bottom, corners -->
        <Border Width="6" HorizontalAlignment="Left" VerticalAlignment="Stretch" Background="Transparent"
                Cursor="LeftSide" PointerPressed="ResizeWest_PointerPressed" />
        <Border Width="6" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent"
                Cursor="RightSide" PointerPressed="ResizeEast_PointerPressed" />
        <Border Height="6" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Background="Transparent"
                Cursor="BottomSide" PointerPressed="ResizeSouth_PointerPressed" />
        <Border Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent"
                Cursor="TopLeftCorner" PointerPressed="ResizeNorthWest_PointerPressed" />
        <Border Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent"
                Cursor="TopRightCorner" PointerPressed="ResizeNorthEast_PointerPressed" />
        <Border Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="Transparent"
                Cursor="BottomLeftCorner" PointerPressed="ResizeSouthWest_PointerPressed" />
        <Border Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent"
                Cursor="BottomRightCorner" PointerPressed="ResizeSouthEast_PointerPressed" />
    </Grid>

</Window>
