<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AutoPBR.App.ViewModels"
        xmlns:rvm="using:AutoPBR.App.ViewModels.Rulesets"
        xmlns:m="using:AutoPBR.App.Models"
        xmlns:ctrls="using:AutoPBR.App.Controls"
        xmlns:stage="using:AutoPBR.App.Rendering.Scene"
        xmlns:appConv="using:AutoPBR.App.Converters"
        xmlns:core="using:AutoPBR.Core.Models"
        xmlns:expr="using:AutoPBR.Core.Models.RuleExpressions"
        xmlns:converters="using:Avalonia.Data.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AutoPBR.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/AutoPBR-logo.ico"
        Title="{Binding Strings.AppTitle}"
        Width="1000"
        Height="720"
        SystemDecorations="None"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="None">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Long filesystem paths inflate TextBox desired width and stretch parent grids; keep compact until focused. -->
        <Style Selector="TextBox.path-entry">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MaxWidth" Value="440" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style Selector="TextBox.path-entry:focus">
            <Setter Property="MaxWidth" Value="10000" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.preview-help-btn">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.preview-help-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.92" />
        </Style>
        <Style Selector="Button.preview-help-btn:pressed">
            <Setter Property="Opacity" Value="0.78" />
        </Style>
    </Window.Styles>
    <Window.Resources>
        <appConv:ConditionValueOptionsConverter x:Key="ConditionValueOptionsConverter" />
        <appConv:ActionValueOptionsConverter x:Key="ActionValueOptionsConverter" />
        <StreamGeometry x:Key="PreviewCameraHelpIcon">M8,1.33333333 C4.318,1.33333333 1.33333333,4.318 1.33333333,8 C1.33333333,11.682 4.318,14.6666667 8,14.6666667 C11.682,14.6666667 14.6666667,11.682 14.6666667,8 C14.6666667,4.318 11.682,1.33333333 8,1.33333333 Z M8.33333333,11.6666667 C8.33333333,12.2186667 7.88533333,12.6666667 7.33333333,12.6666667 C6.78133333,12.6666667 6.33333333,12.2186667 6.33333333,11.6666667 C6.33333333,11.1146667 6.78133333,10.6666667 7.33333333,10.6666667 C7.88533333,10.6666667 8.33333333,11.1146667 8.33333333,11.6666667 Z M9.16666667,6.11333333 C8.94761117,5.44971417 8.3582405,4.9664335 7.66666667,4.96666667 C6.74619083,4.96666667 6,5.7128575 6,6.63333333 L6.96666667,6.63333333 C6.96666667,6.24652333 7.27985683,5.93333333 7.66666667,5.93333333 C8.0534765,5.93333333 8.36666667,6.24652333 8.36666667,6.63333333 C8.36666667,6.930215 8.18204833,7.19117167 7.91122667,7.30318 C7.538535,7.45799833 7.26666667,7.83007 7.26666667,8.25466667 L7.26666667,8.63333333 L8.23333333,8.63333333 L8.23333333,8.25466667 C8.23333333,7.99381 8.37773833,7.75453 8.60958,7.63518 C9.090465,7.385425 9.4,6.87922833 9.4,6.32333333 C9.4,6.24548 9.39189667,6.16988833 9.37664667,6.09711 L9.16666667,6.11333333 Z</StreamGeometry>
    </Window.Resources>

    <Grid>
        <!-- LayoutTransform (not RenderTransform) so measured size matches scaled chrome; window is resized in code when UiScale changes. -->
        <LayoutTransformControl LayoutTransform="{Binding UiScaleTransform}">
        <Border x:Name="RootBorder"
                Background="{Binding WindowBackground}"
                BorderBrush="{Binding CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="1">
        <Grid RowDefinitions="Auto,*,Auto" Background="{Binding WindowBackground}">
        <!-- Custom title bar: logo (left), title (center), window controls (right); flush with content -->
        <Border Grid.Row="0"
                Background="{Binding WindowBackground}"
                Height="40">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="8"
                            Margin="12,0,8,0">
                    <Border Background="Transparent"
                            VerticalAlignment="Center"
                            PointerPressed="TitleBarDragRegion_PointerPressed">
                        <Image Source="/Assets/AutoPBR-logo.png"
                               Width="24"
                               Height="24"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False" />
                    </Border>
                    <ToggleSwitch VerticalAlignment="Center"
                                  OnContent=""
                                  OffContent=""
                                  IsChecked="{Binding UseBatchFolderInput, Mode=TwoWay}"
                                  ToolTip.Tip="{Binding Strings.InputSourceModeTooltip}" />
                </StackPanel>
                <Border x:Name="TitleBarDragRegion"
                        Grid.Column="1"
                        Background="Transparent"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        ClipToBounds="True"
                        PointerPressed="TitleBarDragRegion_PointerPressed">
                    <TextBlock VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="{Binding Strings.AppTitle}"
                               Foreground="{Binding ForegroundBrush}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               IsHitTestVisible="False" />
                </Border>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0">
                    <Button x:Name="MinimizeButton"
                            Width="46" Height="40"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="{Binding Strings.WindowMinimize}"
                            Click="WindowMinimize_Click">
                        <TextBlock Text="&#x2014;" FontSize="14" Foreground="{Binding ForegroundBrush}" />
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Width="46" Height="40"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="{Binding Strings.WindowMaximize}"
                            Click="WindowMaximize_Click">
                        <TextBlock Text="&#x25A1;" FontSize="12" Foreground="{Binding ForegroundBrush}" />
                    </Button>
                    <Button x:Name="CloseButton"
                            Width="46" Height="40"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="{Binding Strings.WindowClose}"
                            Click="WindowClose_Click">
                        <TextBlock Text="&#x2715;" FontSize="12" Foreground="{Binding ForegroundBrush}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ContentGrid" Grid.Row="1" RowDefinitions="*" Background="{Binding WindowBackground}" ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="0" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="280" MinWidth="260" MaxWidth="600" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" RowDefinitions="Auto,*" MinWidth="0">
                <Border Grid.Row="0"
                        Background="{Binding WindowBackground}"
                        BorderBrush="{Binding CardBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Margin="16,8,16,10" Spacing="8" MinWidth="0">
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" MinWidth="0"
                              IsVisible="{Binding UseBatchFolderInput, Converter={x:Static converters:BoolConverters.Not}}">
                            <TextBox Grid.Column="0" MinWidth="0" Watermark="{Binding Strings.ResourcePackWatermark}" Text="{Binding PackPath, Mode=TwoWay}" />
                            <Button Grid.Column="1" Content="{Binding Strings.ScanButton}" Command="{Binding ScanCurrentInputCommand}" />
                            <Button Grid.Column="2" Content="{Binding Strings.Browse}" Click="BrowseInput_Click" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" MinWidth="0"
                              IsVisible="{Binding UseBatchFolderInput}">
                            <TextBox Grid.Column="0" MinWidth="0" Watermark="{Binding Strings.BatchFolderWatermark}" Text="{Binding BatchFolderPath, Mode=TwoWay}" />
                            <Button Grid.Column="1" Content="{Binding Strings.ScanButton}" Command="{Binding ScanCurrentInputCommand}" />
                            <Button Grid.Column="2" Content="{Binding Strings.Browse}" Click="BrowseInput_Click" />
                        </Grid>
                    </StackPanel>
                </Border>
                <Grid Grid.Row="1" MinWidth="0">
            <TabControl x:Name="MainTabControl" Margin="16,8,16,16" ZIndex="0" MinWidth="0">
                <TabItem Header="{Binding Strings.TabExplore}">
                    <Grid Margin="0,12,0,0" MinWidth="0">
                        <!-- Resource explorer: conversion filter checkboxes (folder scope); toolbars use WrapPanel for narrow windows -->
                        <Border MinHeight="200" MinWidth="0" VerticalAlignment="Stretch"
                                CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="16">
                            <Grid RowDefinitions="Auto,Auto,*" MinWidth="0">
                                <StackPanel Grid.Row="0" Spacing="10" MinWidth="0">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.ResourceExplorer}" TextWrapping="Wrap" />
                                    <StackPanel x:Name="ExplorePanel" Margin="0,8,0,0" Spacing="8" MinWidth="0">
                                        <!-- Row 1: filter / tag / foliage -->
                                        <WrapPanel Orientation="Horizontal" ItemSpacing="8" LineSpacing="6">
                                            <TextBox Watermark="{Binding Strings.FilterWatermark}" Text="{Binding ExploreFilter, Mode=TwoWay}"
                                                     MinWidth="100" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Strings.ExploreTagFilter}" VerticalAlignment="Center" />
                                                <ComboBox ItemsSource="{Binding ExploreTagFilterOptions}"
                                                          SelectedValue="{Binding ExploreTagFilterId, Mode=TwoWay}"
                                                          SelectedValueBinding="{Binding Id}"
                                                          MinWidth="100" MaxWidth="280"
                                                          PlaceholderText="{Binding Strings.ExploreTagFilterAll}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="m:ExploreTagFilterOption">
                                                            <TextBlock Text="{Binding DisplayName}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Strings.Foliage}" VerticalAlignment="Center"
                                                           ToolTip.Tip="{Binding Strings.FoliageTooltip}" />
                                                <ComboBox MinWidth="100" MaxWidth="200" ItemsSource="{Binding FoliageModeOptions}"
                                                          SelectedItem="{Binding SelectedFoliageMode, Mode=TwoWay}"
                                                          ToolTip.Tip="{Binding Strings.FoliageTooltip}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:FoliageModeOption">
                                                            <TextBlock Text="{Binding DisplayName}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                            <ctrls:FlyoutSection HorizontalAlignment="Left"
                                                                 ButtonMinWidth="120"
                                                                 FlyoutMaxWidth="400"
                                                                 Header="{Binding Strings.AiTaggingSection}"
                                                                 HeaderToolTip="{Binding Strings.MaterialTagSemanticMlDescription}">
                                                <StackPanel Spacing="8">
                                                    <CheckBox Content="{Binding Strings.UseSemanticMaterialTags}"
                                                              IsChecked="{Binding UseSemanticMaterialTags, Mode=TwoWay}"
                                                              ToolTip.Tip="{Binding Strings.MaterialTagSemanticMlDescription}" />
                                                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MaterialTagMinSimilarity}" TextWrapping="Wrap" />
                                                        <ctrls:OverlaySlider Grid.Column="1" Minimum="0.05" Maximum="0.95" SmallChange="0.05" LargeChange="0.1" Value="{Binding MaterialTagMinSimilarity, Mode=TwoWay}" Increment="0.05" FormatString="0.##" HorizontalAlignment="Left" />
                                                    </Grid>
                                                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MaterialTagCertaintyThreshold}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.MaterialTagCertaintyThresholdTooltip}" />
                                                        <ctrls:OverlaySlider Grid.Column="1" Minimum="0.05" Maximum="0.95" SmallChange="0.05" LargeChange="0.1" Value="{Binding MaterialTagCertaintyThreshold, Mode=TwoWay}" Increment="0.05" FormatString="0.##" ToolTip.Tip="{Binding Strings.MaterialTagCertaintyThresholdTooltip}" HorizontalAlignment="Left" />
                                                    </Grid>
                                                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MaterialTagMaxCount}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.MaterialTagMaxCountTooltip}" />
                                                        <ctrls:OverlaySlider Grid.Column="1" Minimum="1" Maximum="16" SmallChange="1" LargeChange="1" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding MaterialTagMaxCount, Mode=TwoWay}" Increment="1" FormatString="0" ToolTip.Tip="{Binding Strings.MaterialTagMaxCountTooltip}" HorizontalAlignment="Left" />
                                                    </Grid>
                                                    <CheckBox Content="{Binding Strings.DictionaryEvidenceEnabled}" IsChecked="{Binding DictionaryEvidenceEnabled, Mode=TwoWay}" />
                                                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsEnabled="{Binding DictionaryEvidenceEnabled}">
                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.DictionaryEvidenceWeight}" TextWrapping="Wrap" />
                                                        <ctrls:OverlaySlider Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1" Value="{Binding DictionaryEvidenceWeight, Mode=TwoWay}" Increment="0.05" FormatString="0.##" HorizontalAlignment="Left" />
                                                    </Grid>
                                                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsEnabled="{Binding DictionaryEvidenceEnabled}">
                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.DictionaryMinEvidenceScore}" TextWrapping="Wrap" />
                                                        <ctrls:OverlaySlider Grid.Column="1" Minimum="-1" Maximum="1" SmallChange="0.05" LargeChange="0.1" Value="{Binding DictionaryMinEvidenceScore, Mode=TwoWay}" Increment="0.05" FormatString="0.##" HorizontalAlignment="Left" />
                                                    </Grid>
                                                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsEnabled="{Binding DictionaryEvidenceEnabled}">
                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.DictionaryRequestTimeoutMs}" TextWrapping="Wrap" />
                                                        <ctrls:OverlaySlider Grid.Column="1" Minimum="100" Maximum="5000" SmallChange="100" LargeChange="500" TickFrequency="500" Value="{Binding DictionaryRequestTimeoutMs, Mode=TwoWay}" Increment="100" FormatString="0" HorizontalAlignment="Left" BoxMinWidth="88" />
                                                    </Grid>
                                                </StackPanel>
                                            </ctrls:FlyoutSection>
                                        </WrapPanel>
                                        <!-- Row 2: navigation + conversion checkboxes (wrap together when squished) -->
                                        <WrapPanel Orientation="Horizontal" ItemSpacing="8" LineSpacing="8">
                                            <Button Content="{Binding Strings.ExploreBack}" Command="{Binding GoBackExploreCommand}"
                                                    IsEnabled="{Binding CanGoBackExplore}" />
                                            <ItemsControl ItemsSource="{Binding ExploreBreadcrumb}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" ItemSpacing="4" LineSpacing="4" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="m:ArchiveNode">
                                                        <Button Content="{Binding Name}"
                                                                Command="{Binding #ExplorePanel.((vm:MainWindowViewModel)DataContext).GoToBreadcrumbCommand, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                CommandParameter="{Binding}" Padding="4,2" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Button Content="{Binding Strings.ExploreExpandAll}" Command="{Binding ExploreExpandAllCommand}" />
                                            <Button Content="{Binding Strings.ExploreCollapseAll}" Command="{Binding ExploreCollapseAllCommand}" />
                                            <Button Content="{Binding Strings.RefreshTagRules}" Command="{Binding Rulesets.RefreshTagRulesCommand}"
                                                    IsVisible="{Binding HasScannedArchive}"
                                                    ToolTip.Tip="{Binding Strings.RefreshTagRulesTooltip}" />
                                            <Button Content="{Binding Strings.ClearTagOverrides}" Command="{Binding ClearTagOverridesCommand}"
                                                    IsVisible="{Binding HasScannedArchive}"
                                                    ToolTip.Tip="{Binding Strings.ClearTagOverridesTooltip}" />
                                            <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="6">
                                                <CheckBox FontSize="12" Content="{Binding Strings.Blocks}" IsChecked="{Binding ProcessBlocks, Mode=TwoWay}"
                                                          ToolTip.Tip="{Binding Strings.BlocksTooltip}" />
                                                <CheckBox FontSize="12" Content="{Binding Strings.Items}" IsChecked="{Binding ProcessItems, Mode=TwoWay}"
                                                          ToolTip.Tip="{Binding Strings.ItemsTooltip}" />
                                                <CheckBox FontSize="12" Content="{Binding Strings.Armor}" IsChecked="{Binding ProcessArmor, Mode=TwoWay}"
                                                          ToolTip.Tip="{Binding Strings.ArmorTooltip}" />
                                                <CheckBox FontSize="12" Content="{Binding Strings.Entity}" IsChecked="{Binding ProcessEntity, Mode=TwoWay}"
                                                          ToolTip.Tip="{Binding Strings.EntityTooltip}" />
                                                <CheckBox FontSize="12" IsChecked="{Binding ProcessParticles, Mode=TwoWay}"
                                                          ToolTip.Tip="{Binding Strings.ParticlesTooltip}">
                                                    <TextBlock FontSize="12" Text="{Binding Strings.Particles}" TextWrapping="Wrap" />
                                                </CheckBox>
                                            </WrapPanel>
                                        </WrapPanel>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Row="1" MinWidth="0" Margin="0,8,0,0" Padding="8,6"
                                        Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}"
                                        BorderThickness="1,1,1,0" CornerRadius="8,8,0,0" ClipToBounds="True">
                                    <Grid x:Name="ExploreTreeHeaderGrid" MinWidth="0" ColumnSpacing="0" ClipToBounds="True">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="{Binding ExploreTreeColumnResourceWidth, Mode=TwoWay}" MinWidth="48" />
                                            <ColumnDefinition Width="6" MinWidth="6" MaxWidth="6" />
                                            <ColumnDefinition Width="{Binding ExploreTreeColumnMaterialsWidth, Mode=TwoWay}" MinWidth="48" />
                                            <ColumnDefinition Width="6" MinWidth="6" MaxWidth="6" />
                                            <ColumnDefinition Width="{Binding ExploreTreeColumnFlagsWidth, Mode=TwoWay}" MinWidth="48" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" ClipToBounds="True" BorderBrush="{Binding CardBorderBrush}" BorderThickness="0,0,1,0"
                                                Padding="4,0,8,0">
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Opacity="0.95" VerticalAlignment="Center"
                                                       HorizontalAlignment="Left" TextAlignment="Left"
                                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                       Text="{Binding Strings.ExploreColumnResource}"
                                                       ToolTip.Tip="{Binding Strings.ExploreColumnResource}" />
                                        </Border>
                                        <GridSplitter Grid.Column="1" Width="6" ResizeDirection="Columns" ShowsPreview="False"
                                                      Background="#28FFFFFF" Cursor="SizeWestEast"
                                                      PointerMoved="ExploreTreeHeaderSplitter_OnPointerMoved"
                                                      PointerReleased="ExploreTreeHeaderSplitter_OnPointerReleased" />
                                        <Border Grid.Column="2" ClipToBounds="True" BorderBrush="{Binding CardBorderBrush}" BorderThickness="0,0,1,0"
                                                Padding="4,0,8,0">
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Opacity="0.95" VerticalAlignment="Center"
                                                       HorizontalAlignment="Stretch" TextAlignment="Center"
                                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                       Text="{Binding Strings.TagLegendMaterials}"
                                                       ToolTip.Tip="{Binding Strings.TagLegendMaterials}" />
                                        </Border>
                                        <GridSplitter Grid.Column="3" Width="6" ResizeDirection="Columns" ShowsPreview="False"
                                                      Background="#28FFFFFF" Cursor="SizeWestEast"
                                                      PointerMoved="ExploreTreeHeaderSplitter_OnPointerMoved"
                                                      PointerReleased="ExploreTreeHeaderSplitter_OnPointerReleased" />
                                        <Border Grid.Column="4" ClipToBounds="True" BorderBrush="{Binding CardBorderBrush}" BorderThickness="0,0,0,0"
                                                Padding="4,0,4,0">
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Opacity="0.95" VerticalAlignment="Center"
                                                       HorizontalAlignment="Stretch" TextAlignment="Center"
                                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                       Text="{Binding Strings.TagLegendFlags}"
                                                       ToolTip.Tip="{Binding Strings.TagLegendFlags}" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border Grid.Row="2" MinWidth="0" Padding="0" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}"
                                        BorderThickness="1" CornerRadius="0,0,8,8" MinHeight="120">
                                    <Grid MinWidth="0">
                                        <Grid IsVisible="{Binding ShowExploreEmptyMessage}" MinHeight="120">
                                            <TextBlock Text="{Binding Strings.ExploreEmptyMessage}"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="24,16"
                                                       MaxWidth="520"
                                                       Opacity="0.85"
                                                       FontSize="13" />
                                        </Grid>
                                    <ScrollViewer x:Name="ExploreTreeScrollViewer"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto"
                                                  IsVisible="{Binding HasScannedArchive}">
                                        <TreeView ItemsSource="{Binding ExploreViewItems}"
                                                  x:Name="ExploreTreeView"
                                                  SelectionMode="Multiple"
                                                  SelectedItem="{Binding SelectedExploreNode, Mode=TwoWay}">
                                            <TreeView.Styles>
                                                <Style Selector="TreeViewItem">
                                                    <Setter Property="IsExpanded"
                                                            Value="{Binding $self.((m:ArchiveNode)DataContext).IsExpanded, Mode=TwoWay, FallbackValue=False, TargetNullValue=False}" />
                                                    <Setter Property="IsVisible">
                                                        <Setter.Value>
                                                            <Binding Path="$self.((m:ArchiveNode)DataContext).IsVisibleByFilter"
                                                                     FallbackValue="True"
                                                                     TargetNullValue="True" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                                <Style Selector="Border.preview-row-host Button.preview-btn">
                                                    <Setter Property="Opacity" Value="0" />
                                                    <Setter Property="IsHitTestVisible" Value="False" />
                                                </Style>
                                                <Style Selector="Border.preview-row-host:pointerover Button.preview-btn">
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Setter Property="IsHitTestVisible" Value="True" />
                                                </Style>
                                            </TreeView.Styles>
                                            <TreeView.DataTemplates>
                                                <TreeDataTemplate DataType="m:ArchiveNode" ItemsSource="{Binding Children}">
                                                    <Border Classes="preview-row-host" Background="Transparent" Padding="0">
                                                        <Border.ContextMenu>
                                                            <ContextMenu IsVisible="{Binding !IsFolder}">
                                                                <MenuItem Header="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).Strings.TagLegendMaterials, FallbackValue='', TargetNullValue=''}"
                                                                          ItemsSource="{Binding MaterialTagMenuItems}">
                                                                    <MenuItem.ItemTemplate>
                                                                        <DataTemplate x:DataType="m:TagMenuEntry">
                                                                            <MenuItem ToggleType="CheckBox"
                                                                                      IsChecked="{Binding IsApplied, Mode=TwoWay}">
                                                                                <MenuItem.Header>
                                                                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                                                        <Image Width="16" Height="16" Stretch="Fill" Source="{Binding TagIcon}" IsVisible="{Binding HasTagIcon}" />
                                                                                        <TextBlock Text="{Binding IconGlyph}" FontSize="14" VerticalAlignment="Center" IsVisible="{Binding !HasTagIcon}" />
                                                                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                                                                    </StackPanel>
                                                                                </MenuItem.Header>
                                                                            </MenuItem>
                                                                        </DataTemplate>
                                                                    </MenuItem.ItemTemplate>
                                                                </MenuItem>
                                                                <MenuItem Header="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).Strings.TagLegendFlags, FallbackValue='', TargetNullValue=''}"
                                                                          ItemsSource="{Binding FlagTagMenuItems}">
                                                                    <MenuItem.ItemTemplate>
                                                                        <DataTemplate x:DataType="m:TagMenuEntry">
                                                                            <MenuItem ToggleType="CheckBox"
                                                                                      IsChecked="{Binding IsApplied, Mode=TwoWay}">
                                                                                <MenuItem.Header>
                                                                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                                                        <Image Width="16" Height="16" Stretch="Fill" Source="{Binding TagIcon}" IsVisible="{Binding HasTagIcon}" />
                                                                                        <TextBlock Text="{Binding IconGlyph}" FontSize="14" VerticalAlignment="Center" IsVisible="{Binding !HasTagIcon}" />
                                                                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                                                                    </StackPanel>
                                                                                </MenuItem.Header>
                                                                            </MenuItem>
                                                                        </DataTemplate>
                                                                    </MenuItem.ItemTemplate>
                                                                </MenuItem>
                                                                <Separator IsVisible="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).UseSemanticMaterialTags, FallbackValue=False, TargetNullValue=False}" />
                                                                <MenuItem Header="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).Strings.DebugMlMatch, FallbackValue='', TargetNullValue=''}"
                                                                          IsVisible="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).UseSemanticMaterialTags, FallbackValue=False, TargetNullValue=False}"
                                                                          Command="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).DebugSemanticMatchCommand, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                          CommandParameter="{Binding}" />
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <Grid ColumnSpacing="0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).ExploreTreeColumnResourceWidth, FallbackValue=48, TargetNullValue=48}" MinWidth="48" />
                                                                <ColumnDefinition Width="6" MinWidth="6" MaxWidth="6" />
                                                                <ColumnDefinition Width="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).ExploreTreeColumnMaterialsWidth, FallbackValue=48, TargetNullValue=48}" MinWidth="48" />
                                                                <ColumnDefinition Width="6" MinWidth="6" MaxWidth="6" />
                                                                <ColumnDefinition Width="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).ExploreTreeColumnFlagsWidth, FallbackValue=48, TargetNullValue=48}" MinWidth="48" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" ClipToBounds="True" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                                                                    <CheckBox IsChecked="{Binding ManualOverride, Mode=TwoWay}" IsThreeState="True"
                                                                        ToolTip.Tip="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).Strings.ExploreManualOverrideTooltip, FallbackValue='', TargetNullValue=''}" />
                                                                    <Grid IsVisible="{Binding IsBatchPackRoot}" Width="16" Height="16">
                                                                        <Image Source="{Binding PackIcon}" Width="16" Height="16"
                                                                               IsVisible="{Binding HasPackIcon}"
                                                                               VerticalAlignment="Center" />
                                                                        <Image Source="avares://AutoPBR.App/Assets/AutoPBR-logo.png" Width="16" Height="16"
                                                                               IsVisible="{Binding !HasPackIcon}"
                                                                               VerticalAlignment="Center" />
                                                                    </Grid>
                                                                    <Button Command="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).EnterFolderCommand, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                            CommandParameter="{Binding}" IsVisible="{Binding IsFolder}" Padding="2,0">
                                                                        <ctrls:MinecraftFormattedTextBlock FormattedText="{Binding Name}" VerticalAlignment="Center" />
                                                                    </Button>
                                                                    <ctrls:MinecraftFormattedTextBlock FormattedText="{Binding Name}" VerticalAlignment="Center" IsVisible="{Binding !IsFolder}" />
                                                                    <Button Classes="preview-btn"
                                                                            Content="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).Strings.SetAsPreview, FallbackValue='', TargetNullValue=''}"
                                                                            Command="{Binding #ExploreTreeView.((vm:MainWindowViewModel)DataContext).SetPreviewTextureCommand, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                            CommandParameter="{Binding}"
                                                                            IsVisible="{Binding !IsFolder}"
                                                                            Padding="4,2" />
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Grid.Column="2" ClipToBounds="True" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                                    IsVisible="{Binding !IsFolder}">
                                                                <ItemsControl ItemsSource="{Binding MaterialDisplayTags}"
                                                                              VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Orientation="Horizontal" Spacing="4" />
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="m:DisplayTagItem">
                                                                            <Border ToolTip.Tip="{Binding DisplayName}" Padding="2,0" Background="Transparent">
                                                                                <Panel>
                                                                                    <Image Width="16" Height="16" Stretch="Fill" Source="{Binding TagIcon}" IsVisible="{Binding HasTagIcon}" />
                                                                                    <TextBlock Text="{Binding IconGlyph}" FontSize="14" VerticalAlignment="Center" IsVisible="{Binding !HasTagIcon}" />
                                                                                </Panel>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Border>
                                                            <Border Grid.Column="4" ClipToBounds="True" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                                    IsVisible="{Binding !IsFolder}">
                                                                <ItemsControl ItemsSource="{Binding FlagDisplayTags}"
                                                                              VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Orientation="Horizontal" Spacing="4" />
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="m:DisplayTagItem">
                                                                            <Border ToolTip.Tip="{Binding DisplayName}" Padding="2,0" Background="Transparent" Opacity="0.92">
                                                                                <Panel>
                                                                                    <Image Width="16" Height="16" Stretch="Fill" Source="{Binding TagIcon}" IsVisible="{Binding HasTagIcon}" />
                                                                                    <TextBlock Text="{Binding IconGlyph}" FontSize="13" VerticalAlignment="Center" IsVisible="{Binding !HasTagIcon}" />
                                                                                </Panel>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </TreeDataTemplate>
                                            </TreeView.DataTemplates>
                                        </TreeView>
                                    </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="{Binding Strings.TabNormals}">
                    <ScrollViewer x:Name="TuneTabScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <Grid MinWidth="0" HorizontalAlignment="Stretch"
                          MaxWidth="{Binding #TuneTabScrollViewer.Viewport.Width}">
                    <StackPanel Margin="0,12,0,0" Spacing="12" MinWidth="0">
                        <!-- Normals + height: tuning | AI -->
                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="12" MinWidth="0">
                            <ctrls:ReflowColumnsPanel MaxColumns="2" MinColumnWidth="360" ColumnSpacing="20" MinWidth="0">
                                <StackPanel Spacing="10" MinWidth="0">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.NormalsAndHeightSection}" TextWrapping="Wrap" />
                                    <ctrls:ReflowColumnsPanel MaxColumns="2" MinColumnWidth="220" ColumnSpacing="16" MinWidth="0">
                                        <StackPanel Spacing="8" MinWidth="0">
                                            <ctrls:FlyoutSection Header="{Binding Strings.NormalsSection}">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                                                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.NormalStrength}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.NormalStrengthTooltip}" />
                                                        <ctrls:OverlaySlider Grid.Row="0" Grid.Column="1" Minimum="0.1" Maximum="8" SmallChange="0.01" LargeChange="0.1" Value="{Binding NormalIntensity, Mode=TwoWay}" Increment="0.01" FormatString="0.##" ToolTip.Tip="{Binding Strings.NormalStrengthTooltip}" HorizontalAlignment="Left" />
                                                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.NormalOperatorLabel}" TextWrapping="Wrap" />
                                                        <ComboBox Grid.Row="1" Grid.Column="1" MinWidth="140" MaxWidth="220" HorizontalAlignment="Left" ItemsSource="{Binding NormalOperatorOptions}" SelectedItem="{Binding SelectedNormalOperator, Mode=TwoWay}">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:FoliageModeOption">
                                                                    <TextBlock Text="{Binding DisplayName}" />
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.NormalKernelSizeLabel}" TextWrapping="Wrap" />
                                                        <ComboBox Grid.Row="2" Grid.Column="1" MinWidth="140" MaxWidth="220" HorizontalAlignment="Left" ItemsSource="{Binding NormalKernelSizeOptions}" SelectedItem="{Binding SelectedNormalKernelSize, Mode=TwoWay}">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:FoliageModeOption">
                                                                    <TextBlock Text="{Binding DisplayName}" />
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Derivative}" TextWrapping="Wrap" />
                                                        <ComboBox Grid.Row="3" Grid.Column="1" MinWidth="140" MaxWidth="220" HorizontalAlignment="Left" ItemsSource="{Binding NormalDerivativeOptions}" SelectedItem="{Binding SelectedNormalDerivative, Mode=TwoWay}">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:FoliageModeOption">
                                                                    <TextBlock Text="{Binding DisplayName}" />
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </Grid>
                                                </StackPanel>
                                            </ctrls:FlyoutSection>
                                            <ctrls:FlyoutSection Header="{Binding Strings.TuneHeight}">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.HeightStrength}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.HeightStrengthTooltip}" />
                                                        <ctrls:OverlaySlider Grid.Column="1" Minimum="0.001" Maximum="2" SmallChange="0.001" LargeChange="0.01" Value="{Binding HeightIntensity, Mode=TwoWay}" Increment="0.001" FormatString="0.##" ToolTip.Tip="{Binding Strings.HeightStrengthTooltip}" HorizontalAlignment="Left" />
                                                    </Grid>
                                                    <CheckBox IsChecked="{Binding BrickHeightMapPostProcessEnabled, Mode=TwoWay}" ToolTip.Tip="{Binding Strings.BrickProbeEnableTooltip}">
                                                        <TextBlock Text="{Binding Strings.BrickProbeEnable}" TextWrapping="Wrap" />
                                                    </CheckBox>
                                                    <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6" IsVisible="{Binding BrickHeightMapPostProcessEnabled}">
                                                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.BrickProbeMinStructure}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.BrickProbeMinStructureTooltip}" />
                                                        <ctrls:OverlaySlider Grid.Row="0" Grid.Column="1" Minimum="0.001" Maximum="0.08" SmallChange="0.001" LargeChange="0.005" Value="{Binding BrickHeightMinStructuralConfidence, Mode=TwoWay}" Increment="0.001" FormatString="0.##" ToolTip.Tip="{Binding Strings.BrickProbeMinStructureTooltip}" HorizontalAlignment="Left" />
                                                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.BrickProbeInvertDelta}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.BrickProbeInvertDeltaTooltip}" />
                                                        <ctrls:OverlaySlider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="12" SmallChange="0.1" LargeChange="0.5" Value="{Binding BrickHeightInvertDeltaThreshold, Mode=TwoWay}" Increment="0.1" FormatString="0.##" ToolTip.Tip="{Binding Strings.BrickProbeInvertDeltaTooltip}" HorizontalAlignment="Left" />
                                                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.BrickProbeLightGroutDelta}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.BrickProbeLightGroutDeltaTooltip}" />
                                                        <ctrls:OverlaySlider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="0.08" SmallChange="0.001" LargeChange="0.005" Value="{Binding BrickLightGroutDiffuseDeltaMin, Mode=TwoWay}" Increment="0.001" FormatString="0.##" ToolTip.Tip="{Binding Strings.BrickProbeLightGroutDeltaTooltip}" HorizontalAlignment="Left" />
                                                    </Grid>
                                                </StackPanel>
                                            </ctrls:FlyoutSection>
                                        </StackPanel>
                                        <StackPanel Spacing="8" MinWidth="0">
                                            <ctrls:FlyoutSection Header="{Binding Strings.Preprocessing}">
                                                <StackPanel Spacing="8">
                                                    <CheckBox IsChecked="{Binding PreprocessLinearize, Mode=TwoWay}">
                                                        <TextBlock Text="{Binding Strings.PreprocessLinearize}" TextWrapping="Wrap" />
                                                    </CheckBox>
                                                    <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                                                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.PreprocessDenoiseRadius}" TextWrapping="Wrap" />
                                                        <ctrls:OverlaySlider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="6" SmallChange="1" LargeChange="1" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding PreprocessDenoiseRadius, Mode=TwoWay}" Increment="1" FormatString="0.##" HorizontalAlignment="Left" />
                                                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.PreprocessDenoiseBlend}" TextWrapping="Wrap" />
                                                        <ctrls:OverlaySlider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1" Value="{Binding PreprocessDenoiseBlend, Mode=TwoWay}" Increment="0.05" FormatString="0.##" HorizontalAlignment="Left" />
                                                    </Grid>
                                                    <CheckBox IsChecked="{Binding PreprocessFrequencySplit, Mode=TwoWay}">
                                                        <TextBlock Text="{Binding Strings.PreprocessFrequencySplit}" TextWrapping="Wrap" />
                                                    </CheckBox>
                                                    <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="6" IsVisible="{Binding PreprocessFrequencySplit}">
                                                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.PreprocessFrequencyRadius}" TextWrapping="Wrap" />
                                                        <ctrls:OverlaySlider Grid.Row="0" Grid.Column="1" Minimum="1" Maximum="12" SmallChange="1" LargeChange="1" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding PreprocessFrequencyRadius, Mode=TwoWay}" Increment="1" FormatString="0.##" HorizontalAlignment="Left" />
                                                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.PreprocessFrequencyDetailStrength}" TextWrapping="Wrap" />
                                                        <ctrls:OverlaySlider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="2" SmallChange="0.05" LargeChange="0.1" Value="{Binding PreprocessFrequencyDetailStrength, Mode=TwoWay}" Increment="0.05" FormatString="0.##" HorizontalAlignment="Left" />
                                                    </Grid>
                                                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.NormalHeightTransparentAlphaClampMax}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.NormalHeightTransparentAlphaClampMaxTooltip}" />
                                                        <ctrls:OverlaySlider Grid.Column="1" Minimum="0" Maximum="255" SmallChange="1" LargeChange="8" TickFrequency="16" IsSnapToTickEnabled="True" Value="{Binding NormalHeightTransparentAlphaClampMax, Mode=TwoWay}" Increment="1" FormatString="0" ToolTip.Tip="{Binding Strings.NormalHeightTransparentAlphaClampMaxTooltip}" HorizontalAlignment="Left" />
                                                    </Grid>
                                                </StackPanel>
                                            </ctrls:FlyoutSection>
                                            <ctrls:FlyoutSection Header="{Binding Strings.AoAdvanced}">
                                                <StackPanel Spacing="8">
                                                    <CheckBox IsChecked="{Binding GenerateAo, Mode=TwoWay}">
                                                        <TextBlock Text="{Binding Strings.GenerateAo}" TextWrapping="Wrap" />
                                                    </CheckBox>
                                                    <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="6" IsVisible="{Binding GenerateAo}">
                                                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.AoRadius}" TextWrapping="Wrap" />
                                                        <ctrls:OverlaySlider Grid.Row="0" Grid.Column="1" Minimum="1" Maximum="24" SmallChange="1" LargeChange="1" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding AoRadius, Mode=TwoWay}" Increment="1" FormatString="0.##" HorizontalAlignment="Left" />
                                                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.AoStrength}" TextWrapping="Wrap" />
                                                        <ctrls:OverlaySlider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="3" SmallChange="0.05" LargeChange="0.1" Value="{Binding AoStrength, Mode=TwoWay}" Increment="0.05" FormatString="0.##" HorizontalAlignment="Left" />
                                                    </Grid>
                                                </StackPanel>
                                            </ctrls:FlyoutSection>
                                        </StackPanel>
                                    </ctrls:ReflowColumnsPanel>
                                </StackPanel>
                                <StackPanel Spacing="10" MinWidth="0">
                                    <Border Classes="tune-specular-divider" BorderBrush="{Binding CardBorderBrush}">
                                        <StackPanel Spacing="10" MinWidth="0">
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.TuneSpecular}" TextWrapping="Wrap" />
                                            <ctrls:ReflowColumnsPanel MaxColumns="2" MinColumnWidth="220" ColumnSpacing="16" MinWidth="0">
                                                <StackPanel Spacing="8" MinWidth="0">
                                                    <ctrls:FlyoutSection Header="{Binding Strings.SpecularSection}">
                                                        <StackPanel Spacing="8">
                                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.SmoothnessScale}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.SmoothnessScaleTooltip}" />
                                                                <ctrls:OverlaySlider Grid.Column="1" Minimum="0.2" Maximum="3" SmallChange="0.05" LargeChange="0.1" Value="{Binding SmoothnessScale, Mode=TwoWay}" Increment="0.05" FormatString="0.##" ToolTip.Tip="{Binding Strings.SmoothnessScaleTooltip}" HorizontalAlignment="Left" />
                                                            </Grid>
                                                            <CheckBox IsChecked="{Binding SpecularUsePercentileRemap, Mode=TwoWay}">
                                                                <TextBlock Text="{Binding Strings.SpecularPercentileRemap}" TextWrapping="Wrap" />
                                                            </CheckBox>
                                                            <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="6" IsVisible="{Binding SpecularUsePercentileRemap}">
                                                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.SpecularRemapLowPercentile}" TextWrapping="Wrap" />
                                                                <ctrls:OverlaySlider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="0.5" SmallChange="0.01" LargeChange="0.05" Value="{Binding SpecularRemapLowPercentile, Mode=TwoWay}" Increment="0.01" FormatString="0.##" HorizontalAlignment="Left" />
                                                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.SpecularRemapHighPercentile}" TextWrapping="Wrap" />
                                                                <ctrls:OverlaySlider Grid.Row="1" Grid.Column="1" Minimum="0.5" Maximum="1" SmallChange="0.01" LargeChange="0.05" Value="{Binding SpecularRemapHighPercentile, Mode=TwoWay}" Increment="0.01" FormatString="0.##" HorizontalAlignment="Left" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </ctrls:FlyoutSection>
                                                    <ctrls:FlyoutSection Header="{Binding Strings.MetalnessSection}">
                                                        <StackPanel Spacing="8">
                                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MetallicBoost}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.MetallicBoostTooltip}" />
                                                                <ctrls:OverlaySlider Grid.Column="1" Minimum="0" Maximum="3" SmallChange="0.05" LargeChange="0.1" Value="{Binding MetallicBoost, Mode=TwoWay}" Increment="0.05" FormatString="0.##" ToolTip.Tip="{Binding Strings.MetallicBoostTooltip}" HorizontalAlignment="Left" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </ctrls:FlyoutSection>
                                                </StackPanel>
                                                <StackPanel Spacing="8" MinWidth="0">
                                                    <ctrls:FlyoutSection Header="{Binding Strings.SpecularPorositySection}">
                                                        <StackPanel Spacing="8">
                                                            <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                                                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.PorosityBias}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.PorosityBiasTooltip}" />
                                                                <ctrls:OverlaySlider Grid.Row="0" Grid.Column="1" Minimum="-128" Maximum="128" SmallChange="1" LargeChange="8" Value="{Binding PorosityBias, Mode=TwoWay}" Increment="1" FormatString="0.##" ToolTip.Tip="{Binding Strings.PorosityBiasTooltip}" HorizontalAlignment="Left" />
                                                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.PlantMaterialPorosityExtra}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.PlantMaterialPorosityExtraTooltip}" />
                                                                <ctrls:OverlaySlider Grid.Row="1" Grid.Column="1" Minimum="-128" Maximum="128" SmallChange="1" LargeChange="8" Value="{Binding PlantMaterialPorosityExtra, Mode=TwoWay}" Increment="1" FormatString="0.##" ToolTip.Tip="{Binding Strings.PlantMaterialPorosityExtraTooltip}" HorizontalAlignment="Left" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </ctrls:FlyoutSection>
                                                    <ctrls:FlyoutSection Header="{Binding Strings.SpecularAdvanced}">
                                                        <StackPanel Spacing="8">
                                                            <CheckBox IsChecked="{Binding FastSpecular, Mode=TwoWay}" ToolTip.Tip="{Binding Strings.FastSpecularTooltip}">
                                                                <TextBlock Text="{Binding Strings.FastSpecular}" TextWrapping="Wrap" />
                                                            </CheckBox>
                                                            <CheckBox IsChecked="{Binding SpecularForceNoEmissive, Mode=TwoWay}" ToolTip.Tip="{Binding Strings.SpecularForceNoEmissiveTooltip}">
                                                                <TextBlock Text="{Binding Strings.SpecularForceNoEmissive}" TextWrapping="Wrap" />
                                                            </CheckBox>
                                                        </StackPanel>
                                                    </ctrls:FlyoutSection>
                                                </StackPanel>
                                            </ctrls:ReflowColumnsPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ctrls:ReflowColumnsPanel>
                        </Border>

                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="12" MinWidth="0">
                            <StackPanel Spacing="10" MinWidth="0">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.AiDrivenPbrSection}" TextWrapping="Wrap" />
                                <ctrls:ReflowColumnsPanel MaxColumns="2" MinColumnWidth="320" ColumnSpacing="20" MinWidth="0">
                                    <StackPanel Spacing="8" MinWidth="0">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" MinWidth="0">
                                            <ctrls:FlyoutSection Header="{Binding Strings.AiNormalsSection}" Grid.Column="0" HeaderToolTip="{Binding Strings.NormalsFromDeepBumpTooltip}" FlyoutMaxWidth="400">
                                                <StackPanel Spacing="8">
                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.DeepBumpOverlap}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.DeepBumpOverlapTooltip}" />
                                                    <ComboBox Grid.Row="0" Grid.Column="1" Width="120" MinWidth="120" MaxWidth="220" HorizontalAlignment="Left"
                                                              ItemsSource="{Binding DeepBumpOverlapOptions}"
                                                              SelectedItem="{Binding SelectedDeepBumpOverlap, Mode=TwoWay}"
                                                              ToolTip.Tip="{Binding Strings.DeepBumpOverlapTooltip}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding DisplayName}" />
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.DeepBumpInputMode}" TextWrapping="Wrap" />
                                                    <ComboBox Grid.Row="1" Grid.Column="1" MinWidth="140" MaxWidth="220" HorizontalAlignment="Left"
                                                              ItemsSource="{Binding DeepBumpInputModeOptions}"
                                                              SelectedItem="{Binding SelectedDeepBumpInputMode, Mode=TwoWay}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:FoliageModeOption">
                                                                <TextBlock Text="{Binding DisplayName}" />
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                              IsChecked="{Binding DeepBumpForceBlue255, Mode=TwoWay}">
                                                        <TextBlock Text="{Binding Strings.DeepBumpForceBlue255}" TextWrapping="Wrap" />
                                                    </CheckBox>
                                                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"
                                                               Text="{Binding Strings.DeepBumpNormalIntensity}"
                                                               TextWrapping="Wrap"
                                                               ToolTip.Tip="{Binding Strings.DeepBumpNormalIntensityTooltip}" />
                                                    <ctrls:OverlaySlider Grid.Row="3" Grid.Column="1" Minimum="0.05" Maximum="8" SmallChange="0.05" LargeChange="0.1" Value="{Binding DeepBumpNormalIntensity, Mode=TwoWay}" Increment="0.05" FormatString="0.##" ToolTip.Tip="{Binding Strings.DeepBumpNormalIntensityTooltip}" HorizontalAlignment="Left" />
                                                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"
                                                               Text="{Binding Strings.DeepBumpNormalSoftClamp}"
                                                               TextWrapping="Wrap"
                                                               ToolTip.Tip="{Binding Strings.DeepBumpNormalSoftClampTooltip}" />
                                                    <ctrls:OverlaySlider Grid.Row="4" Grid.Column="1" Minimum="0" Maximum="2" SmallChange="0.05" LargeChange="0.1" Value="{Binding DeepBumpNormalSoftClamp, Mode=TwoWay}" Increment="0.05" FormatString="0.##" ToolTip.Tip="{Binding Strings.DeepBumpNormalSoftClampTooltip}" HorizontalAlignment="Left" />
                                                </Grid>
                                                <CheckBox IsChecked="{Binding DeepBumpEdgeGuidedEnhance, Mode=TwoWay}">
                                                    <TextBlock Text="{Binding Strings.DeepBumpEdgeGuidedEnhance}" TextWrapping="Wrap" />
                                                </CheckBox>
                                                <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6"
                                                      IsVisible="{Binding DeepBumpEdgeGuidedEnhance}">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                                               Text="{Binding Strings.DeepBumpEdgeGuidedStrength}"
                                                               TextWrapping="Wrap"
                                                               ToolTip.Tip="{Binding Strings.DeepBumpEdgeGuidedStrengthTooltip}" />
                                                    <ctrls:OverlaySlider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="6" SmallChange="0.05" LargeChange="0.1" Value="{Binding DeepBumpEdgeGuidedStrength, Mode=TwoWay}" Increment="0.05" FormatString="0.##" ToolTip.Tip="{Binding Strings.DeepBumpEdgeGuidedStrengthTooltip}" HorizontalAlignment="Left" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                                               Text="{Binding Strings.DeepBumpEdgeGuidedGamma}"
                                                               TextWrapping="Wrap"
                                                               ToolTip.Tip="{Binding Strings.DeepBumpEdgeGuidedGammaTooltip}" />
                                                    <ctrls:OverlaySlider Grid.Row="1" Grid.Column="1" Minimum="0.1" Maximum="8" SmallChange="0.05" LargeChange="0.1" Value="{Binding DeepBumpEdgeGuidedGamma, Mode=TwoWay}" Increment="0.05" FormatString="0.##" ToolTip.Tip="{Binding Strings.DeepBumpEdgeGuidedGammaTooltip}" HorizontalAlignment="Left" />
                                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                                               Text="{Binding Strings.DeepBumpEdgeGuidedDirectionMix}"
                                                               TextWrapping="Wrap"
                                                               ToolTip.Tip="{Binding Strings.DeepBumpEdgeGuidedDirectionMixTooltip}" />
                                                    <ctrls:OverlaySlider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1" Value="{Binding DeepBumpEdgeGuidedDirectionMix, Mode=TwoWay}" Increment="0.05" FormatString="0.##" ToolTip.Tip="{Binding Strings.DeepBumpEdgeGuidedDirectionMixTooltip}" HorizontalAlignment="Left" />
                                                </Grid>
                                            </StackPanel>
                                            </ctrls:FlyoutSection>
                                            <ToggleSwitch Grid.Column="1"
                                                          VerticalAlignment="Center"
                                                          OnContent=""
                                                          OffContent=""
                                                          IsChecked="{Binding UseDeepBumpNormals, Mode=TwoWay}"
                                                          ToolTip.Tip="{Binding Strings.NormalsFromDeepBumpTooltip}" />
                                        </Grid>
                                    </StackPanel>
                                    <Border Classes="tune-specular-divider" MinWidth="0" BorderBrush="{Binding CardBorderBrush}">
                                        <StackPanel Spacing="8" MinWidth="0">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" MinWidth="0">
                                                <ctrls:FlyoutSection Header="{Binding Strings.AiSpecularSection}" Grid.Column="0" HeaderToolTip="{Binding Strings.UseMlSpecularPredictorTooltip}" FlyoutMaxWidth="520">
                                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6" MinWidth="0">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MlSpecularBlendMode}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.MlSpecularBlendModeTooltip}" />
                                                    <ComboBox Grid.Row="0" Grid.Column="1"
                                                              MinWidth="0"
                                                              HorizontalAlignment="Stretch"
                                                              ItemsSource="{Binding MlSpecularBlendModeOptions}"
                                                              SelectedItem="{Binding SelectedMlSpecularBlendModeOption, Mode=TwoWay}"
                                                              ToolTip.Tip="{Binding Strings.MlSpecularBlendModeTooltip}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate DataType="vm:FoliageModeOption">
                                                                <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap" />
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MlSpecularBlendMath}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.MlSpecularBlendMathTooltip}" />
                                                    <ComboBox Grid.Row="1" Grid.Column="1"
                                                              MinWidth="0"
                                                              HorizontalAlignment="Stretch"
                                                              ItemsSource="{Binding MlSpecularBlendMathOptions}"
                                                              SelectedItem="{Binding SelectedMlSpecularBlendMathOption, Mode=TwoWay}"
                                                              ToolTip.Tip="{Binding Strings.MlSpecularBlendMathTooltip}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate DataType="vm:FoliageModeOption">
                                                                <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap" />
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MlSpecularHeuristicBlend}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.MlSpecularHeuristicBlendTooltip}" />
                                                    <ctrls:OverlaySlider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.05" Value="{Binding MlSpecularHeuristicBlend, Mode=TwoWay}" Increment="0.01" FormatString="0.##" ToolTip.Tip="{Binding Strings.MlSpecularHeuristicBlendTooltip}" HorizontalAlignment="Left" />
                                                    <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                                              HorizontalAlignment="Stretch"
                                                              IsChecked="{Binding MlSpecularUseEdgeChannel, Mode=TwoWay}">
                                                        <TextBlock Text="{Binding Strings.MlSpecularUseEdgeChannel}" TextWrapping="Wrap" />
                                                    </CheckBox>
                                                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"
                                                               Text="{Binding Strings.MlSpecularTransparentAlphaClampMax}"
                                                               TextWrapping="Wrap"
                                                               ToolTip.Tip="{Binding Strings.MlSpecularTransparentAlphaClampMaxTooltip}" />
                                                    <ctrls:OverlaySlider Grid.Row="4" Grid.Column="1" Minimum="0" Maximum="255" SmallChange="1" LargeChange="16" TickFrequency="16" IsSnapToTickEnabled="True" Value="{Binding MlSpecularTransparentAlphaClampMax, Mode=TwoWay}" Increment="1" FormatString="0" ToolTip.Tip="{Binding Strings.MlSpecularTransparentAlphaClampMaxTooltip}" HorizontalAlignment="Left" />
                                                </Grid>
                                                </ctrls:FlyoutSection>
                                                <ToggleSwitch Grid.Column="1"
                                                              VerticalAlignment="Center"
                                                              OnContent=""
                                                              OffContent=""
                                                              IsChecked="{Binding UseMlSpecularPredictor, Mode=TwoWay}"
                                                              ToolTip.Tip="{Binding Strings.UseMlSpecularPredictorTooltip}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </ctrls:ReflowColumnsPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{Binding Strings.TabRulesets}" IsVisible="{Binding DebugMode}">
                    <ScrollViewer x:Name="RulesetsTabScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <Grid MinWidth="0" HorizontalAlignment="Stretch"
                          MaxWidth="{Binding #RulesetsTabScrollViewer.Viewport.Width}">
                    <StackPanel Margin="0,12,0,0" Spacing="12" MinWidth="0" HorizontalAlignment="Stretch">
                        <Border x:Name="TagRulesCard" CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="12" MinWidth="0">
                            <StackPanel Spacing="8" MinWidth="0">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.RulesetsCustomExpressions}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Strings.TagRulesCustomDescription}" TextWrapping="Wrap" Opacity="0.9" />
                                <ItemsControl x:Name="CustomTagRulesList" ItemsSource="{Binding Rulesets.CustomTagRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="core:CustomTagRuleEntry">
                                            <Border Margin="0,0,0,6" Padding="8" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="4">
                                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,Auto" RowSpacing="6" ColumnSpacing="8" MinWidth="0">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleId, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="0" Grid.Column="1" Watermark="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleIdWatermark, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                             Text="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleDisplayName, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="1" Grid.Column="1" Watermark="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleDisplayNameWatermark, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                             Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleKindLabel, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" VerticalAlignment="Center"
                                                               IsVisible="{Binding IsTagDefinition}" />
                                                    <ComboBox Grid.Row="2" Grid.Column="1"
                                                              IsVisible="{Binding IsTagDefinition}"
                                                              ItemsSource="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.TagRuleKindOptions, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                              SelectedItem="{Binding Kind, Mode=TwoWay}" />
                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsKeywords, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" VerticalAlignment="Center"
                                                               IsVisible="{Binding IsTagDefinition}" />
                                                    <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4" IsVisible="{Binding IsTagDefinition}">
                                                        <ItemsControl ItemsSource="{Binding KeywordTokens}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal" ItemSpacing="6" LineSpacing="6" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Padding="6,2" CornerRadius="10" BorderBrush="#40FFFFFF" BorderThickness="1">
                                                                        <TextBlock Text="{Binding .}" TextWrapping="Wrap" MaxWidth="280" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <WrapPanel Orientation="Horizontal" ItemSpacing="6">
                                                            <Button Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsManageTokens, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                    Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.AddKeywordTokenCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                    CommandParameter="{Binding}" />
                                                            <Button Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsRemoveLast, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                    Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.RemoveKeywordTokenCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                    CommandParameter="{Binding}" />
                                                        </WrapPanel>
                                                    </StackPanel>
                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsSemanticHints, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" VerticalAlignment="Center"
                                                               IsVisible="{Binding IsTagDefinition}" />
                                                    <StackPanel Grid.Row="4" Grid.Column="1" Spacing="4" IsVisible="{Binding IsTagDefinition}">
                                                        <ItemsControl ItemsSource="{Binding SemanticHintTokens}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal" ItemSpacing="6" LineSpacing="6" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Padding="6,2" CornerRadius="10" BorderBrush="#40FFFFFF" BorderThickness="1">
                                                                        <TextBlock Text="{Binding .}" TextWrapping="Wrap" MaxWidth="280" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <WrapPanel Orientation="Horizontal" ItemSpacing="6">
                                                            <Button Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsManageTokens, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                    Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.AddSemanticHintTokenCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                    CommandParameter="{Binding}" />
                                                            <Button Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsRemoveLast, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                    Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.RemoveSemanticHintTokenCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                    CommandParameter="{Binding}" />
                                                        </WrapPanel>
                                                    </StackPanel>
                                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsExpression, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" VerticalAlignment="Center" IsVisible="{Binding HasExpression}" />
                                                    <StackPanel Grid.Row="5" Grid.Column="1" Spacing="6" IsVisible="{Binding HasExpression}">
                                                    <StackPanel Spacing="6"
                                                                DataContext="{Binding Expression}">
                                                        <CheckBox Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsEnableExpression, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                  IsChecked="{Binding Enabled, Mode=TwoWay}" />
                                                        <Button Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsAddCondition, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.AddExpressionConditionCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Border}}" />
                                                        <Button Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsAddAction, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.AddExpressionActionCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Border}}" />
                                                        <TextBlock Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsConditions, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" FontWeight="SemiBold" />
                                                        <ItemsControl ItemsSource="{Binding Condition.Children, FallbackValue={x:Null}, TargetNullValue={x:Null}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="expr:RuleConditionNode">
                                                                    <WrapPanel Orientation="Horizontal" ItemSpacing="6" LineSpacing="6">
                                                                        <ComboBox MinWidth="150"
                                                                                  ItemsSource="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.ConditionTypeOptions, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                                  SelectedItem="{Binding Type, Mode=TwoWay}" />
                                                                        <ComboBox MinWidth="180"
                                                                                  SelectedItem="{Binding Value, Mode=TwoWay}">
                                                                            <ComboBox.ItemsSource>
                                                                                <MultiBinding Converter="{StaticResource ConditionValueOptionsConverter}">
                                                                                    <Binding Path="Type" />
                                                                                    <Binding Path="((vm:MainWindowViewModel)DataContext).Rulesets.AvailableTagIds" RelativeSource="{RelativeSource AncestorType=Window}" FallbackValue="{x:Null}" TargetNullValue="{x:Null}" />
                                                                                    <Binding Path="((vm:MainWindowViewModel)DataContext).Rulesets.AvailableFlagIds" RelativeSource="{RelativeSource AncestorType=Window}" FallbackValue="{x:Null}" TargetNullValue="{x:Null}" />
                                                                                </MultiBinding>
                                                                            </ComboBox.ItemsSource>
                                                                        </ComboBox>
                                                                        <TextBox MinWidth="140"
                                                                                 Watermark="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsValueWatermark, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                                 Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                        <Button Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsRemove, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                                Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.RemoveExpressionConditionCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                                CommandParameter="{Binding}" />
                                                                    </WrapPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <TextBlock Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsActions, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" FontWeight="SemiBold" />
                                                        <ItemsControl ItemsSource="{Binding Actions}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="expr:RuleActionDefinition">
                                                                    <WrapPanel Orientation="Horizontal" ItemSpacing="6" LineSpacing="6">
                                                                        <ComboBox MinWidth="150"
                                                                                  ItemsSource="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.ActionTypeOptions, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                                  SelectedItem="{Binding Type, Mode=TwoWay}" />
                                                                        <ComboBox MinWidth="180"
                                                                                  SelectedItem="{Binding Value, Mode=TwoWay}">
                                                                            <ComboBox.ItemsSource>
                                                                                <MultiBinding Converter="{StaticResource ActionValueOptionsConverter}">
                                                                                    <Binding Path="Type" />
                                                                                    <Binding Path="((vm:MainWindowViewModel)DataContext).Rulesets.AvailableTagIds" RelativeSource="{RelativeSource AncestorType=Window}" FallbackValue="{x:Null}" TargetNullValue="{x:Null}" />
                                                                                    <Binding Path="((vm:MainWindowViewModel)DataContext).Rulesets.AvailableFlagIds" RelativeSource="{RelativeSource AncestorType=Window}" FallbackValue="{x:Null}" TargetNullValue="{x:Null}" />
                                                                                </MultiBinding>
                                                                            </ComboBox.ItemsSource>
                                                                        </ComboBox>
                                                                        <Button Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsRemove, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                                Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.RemoveExpressionActionCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                                CommandParameter="{Binding}" />
                                                                    </WrapPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <TextBlock Text="{Binding DisplayName}" Opacity="0.8" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    </StackPanel>
                                                    <WrapPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" ItemSpacing="8" LineSpacing="6" Margin="0,2,0,0">
                                                        <CheckBox Margin="0,0,12,6" Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleEnabled, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" IsChecked="{Binding Enabled, Mode=TwoWay}" ToolTip.Tip="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleEnabledTooltip, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                        <Button Margin="0,0,4,6" Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleMoveUp, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.MoveCustomTagRuleUpCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                CommandParameter="{Binding}" Padding="6,4" ToolTip.Tip="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleMoveUpTooltip, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                        <Button Margin="0,0,4,6" Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleMoveDown, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.MoveCustomTagRuleDownCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                CommandParameter="{Binding}" Padding="6,4" ToolTip.Tip="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleMoveDownTooltip, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                        <Button Margin="0,0,0,6" Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RemoveTagRule, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.RemoveCustomTagRuleCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                CommandParameter="{Binding}" Padding="8,4" />
                                                    </WrapPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <WrapPanel Orientation="Horizontal" ItemSpacing="8" LineSpacing="8">
                                    <Button Content="{Binding Strings.AddCustomTag}" Command="{Binding Rulesets.AddCustomTagCommand}" Padding="8,4" />
                                    <Button Content="{Binding Strings.AddCustomRule}" Command="{Binding Rulesets.AddCustomRuleCommand}" Padding="8,4" />
                                    <Button Content="{Binding Strings.RefreshTagRules}" Command="{Binding Rulesets.RefreshTagRulesCommand}" Padding="8,4"
                                            ToolTip.Tip="{Binding Strings.RefreshTagRulesTooltip}" />
                                    <Button Content="{Binding Strings.ExportTagRules}" Click="ExportTagRules_Click" Padding="8,4"
                                            ToolTip.Tip="{Binding Strings.ExportTagRulesTooltip}" />
                                    <Button Content="{Binding Strings.ImportTagRules}" Click="ImportTagRules_Click" Padding="8,4"
                                            ToolTip.Tip="{Binding Strings.ImportTagRulesTooltip}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="12" MinWidth="0">
                            <StackPanel Spacing="8" MinWidth="0">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.RulesetsBuiltInExpressions}" TextWrapping="Wrap" />
                                <ItemsControl ItemsSource="{Binding Rulesets.BuiltInRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="rvm:RuleDisplayItemViewModel">
                                            <Border Margin="0,0,0,6" Padding="8" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="4" Opacity="0.65">
                                                <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleId, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Id}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleDisplayName, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DisplayName}" />
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsExpression, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ExpressionText}" TextWrapping="Wrap" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" MinWidth="0">
                            <Border Grid.Column="0" CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="12" MinWidth="0">
                                <StackPanel Spacing="8" MinWidth="0">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.RulesetsBuiltInTags}" TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding Rulesets.BuiltInTags}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="rvm:RuleDisplayItemViewModel">
                                                <Border Margin="0,0,0,6" Padding="8" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="4" Opacity="0.65">
                                                    <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleId, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Id}" />
                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleDisplayName, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DisplayName}" />
                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleKindLabel, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Kind}" />
                                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleKeywords, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                        <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4">
                                                        <ItemsControl ItemsSource="{Binding VisibleKeywordTokens}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal" ItemSpacing="6" LineSpacing="6" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Padding="6,2" CornerRadius="10" BorderBrush="#30FFFFFF" BorderThickness="1">
                                                                        <TextBlock Text="{Binding .}" TextWrapping="Wrap" MaxWidth="280" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <Button Content="{Binding MoreKeywordsLabel}"
                                                                IsVisible="{Binding HasHiddenKeywords}"
                                                                Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.ToggleKeywordExpansionCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsShowLess, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                IsVisible="{Binding KeywordsExpanded}"
                                                                Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.ToggleKeywordExpansionCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                CommandParameter="{Binding}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="12" MinWidth="0">
                                <StackPanel Spacing="8" MinWidth="0">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.RulesetsBuiltInFlags}" TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding Rulesets.BuiltInFlags}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="rvm:RuleDisplayItemViewModel">
                                                <Border Margin="0,0,0,6" Padding="8" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="4" Opacity="0.65">
                                                    <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleId, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Id}" />
                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleDisplayName, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DisplayName}" />
                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleKindLabel, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Kind}" />
                                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleKeywords, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                        <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4">
                                                        <ItemsControl ItemsSource="{Binding VisibleKeywordTokens}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal" ItemSpacing="6" LineSpacing="6" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Padding="6,2" CornerRadius="10" BorderBrush="#30FFFFFF" BorderThickness="1">
                                                                        <TextBlock Text="{Binding .}" TextWrapping="Wrap" MaxWidth="280" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <Button Content="{Binding MoreKeywordsLabel}"
                                                                IsVisible="{Binding HasHiddenKeywords}"
                                                                Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.ToggleKeywordExpansionCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="{Binding ((vm:MainWindowViewModel)DataContext).Strings.RulesetsShowLess, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}"
                                                                IsVisible="{Binding KeywordsExpanded}"
                                                                Command="{Binding ((vm:MainWindowViewModel)DataContext).Rulesets.ToggleKeywordExpansionCommand, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                CommandParameter="{Binding}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="12" MinWidth="0">
                            <StackPanel Spacing="8" MinWidth="0">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.RulesetsSystemRules}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Strings.RulesetsSystemRulesDescription}" TextWrapping="Wrap" Opacity="0.85" />
                                <ItemsControl ItemsSource="{Binding Rulesets.SystemComputedRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="rvm:RuleDisplayItemViewModel">
                                            <Border Margin="0,0,0,6" Padding="8" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="4" Opacity="0.65">
                                                <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleId, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Id}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleDisplayName, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DisplayName}" />
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding ((vm:MainWindowViewModel)DataContext).Strings.TagRuleSemanticHints, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='', TargetNullValue=''}" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SemanticHints}" TextWrapping="Wrap" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                    </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{Binding Strings.TabShader}">
                    <ScrollViewer x:Name="ShaderTabScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <Grid MinWidth="0" HorizontalAlignment="Stretch"
                              MaxWidth="{Binding #ShaderTabScrollViewer.Viewport.Width}">
                            <StackPanel Margin="0,12,0,0" Spacing="12" MinWidth="0" HorizontalAlignment="Stretch">
                                <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="12" MinWidth="0">
                                    <StackPanel Spacing="10" MinWidth="0">
                                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.ShaderPreviewLabPbrSection}" TextWrapping="Wrap" />
                                        <ctrls:ReflowColumnsPanel MaxColumns="3" MinColumnWidth="240" ColumnSpacing="16" MinWidth="0">
                                            <StackPanel Spacing="8" MinWidth="0">
                                                <ctrls:FlyoutSection Header="{Binding Strings.Preview3DShadersSection}" FlyoutMaxWidth="720">
                                                    <StackPanel Spacing="8">
                                                        <CheckBox IsChecked="{Binding Preview3DEnableNormalMap, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableNormalMapTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DEnableNormalMap}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                        <CheckBox IsChecked="{Binding Preview3DEnableSpecularMap, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableSpecularMapTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DEnableSpecularMap}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                        <CheckBox IsChecked="{Binding Preview3DEnableSss, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableSssTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DEnableSss}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                        <CheckBox IsChecked="{Binding Preview3DEnableIbl, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableIblTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DEnableIbl}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                        <CheckBox IsChecked="{Binding Preview3DEnableGodRays, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableGodRaysTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DEnableGodRays}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                        <CheckBox IsChecked="{Binding Preview3DEnableVolumetricClouds, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableVolumetricCloudsTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DEnableVolumetricClouds}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                        <CheckBox IsChecked="{Binding Preview3DEnablePreviewTaa, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnablePreviewTaaTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DEnablePreviewTaa}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                        <CheckBox IsChecked="{Binding Preview3DEnableParallax, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableParallaxTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DEnableParallax}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                    </StackPanel>
                                                </ctrls:FlyoutSection>
                                                <ctrls:FlyoutSection Header="{Binding Strings.Preview3DTaaSection}" FlyoutMaxWidth="720">
                                                    <StackPanel Spacing="8">
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DTaaMode}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DTaaModeTooltip}" />
                                                            <ComboBox Grid.Column="1" MinWidth="180" HorizontalAlignment="Left" ItemsSource="{Binding Preview3DTaaModeOptions}" SelectedIndex="{Binding Preview3DTaaMode, Mode=TwoWay}" IsEnabled="{Binding Preview3DEnablePreviewTaa}" ToolTip.Tip="{Binding Strings.Preview3DTaaModeTooltip}" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DTaaTemporalScale}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DTaaTemporalScaleTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.00" Maximum="1.25" SmallChange="0.02" LargeChange="0.10" TickFrequency="0.25" Value="{Binding Preview3DTaaTemporalScale, Mode=TwoWay}" Increment="0.02" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DTaaTemporalScaleTooltip}" IsEnabled="{Binding Preview3DEnablePreviewTaa}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DTaaJitterScale}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DTaaJitterScaleTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.00" Maximum="2.00" SmallChange="0.02" LargeChange="0.10" TickFrequency="0.25" Value="{Binding Preview3DTaaJitterScale, Mode=TwoWay}" Increment="0.02" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DTaaJitterScaleTooltip}" IsEnabled="{Binding Preview3DEnablePreviewTaa}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DTaaSourceFilterScale}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DTaaSourceFilterScaleTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.00" Maximum="2.00" SmallChange="0.02" LargeChange="0.10" TickFrequency="0.25" Value="{Binding Preview3DTaaSourceFilterScale, Mode=TwoWay}" Increment="0.02" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DTaaSourceFilterScaleTooltip}" IsEnabled="{Binding Preview3DEnablePreviewTaa}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DTaaEdgeBlendScale}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DTaaEdgeBlendScaleTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.00" Maximum="2.00" SmallChange="0.02" LargeChange="0.10" TickFrequency="0.25" Value="{Binding Preview3DTaaEdgeBlendScale, Mode=TwoWay}" Increment="0.02" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DTaaEdgeBlendScaleTooltip}" IsEnabled="{Binding Preview3DEnablePreviewTaa}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DTaaFxaaStrengthScale}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DTaaFxaaStrengthScaleTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.00" Maximum="5.00" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.50" Value="{Binding Preview3DTaaFxaaStrengthScale, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DTaaFxaaStrengthScaleTooltip}" IsEnabled="{Binding Preview3DEnablePreviewTaa}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DTaaFxaaLumaEdgeScale}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DTaaFxaaLumaEdgeScaleTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.00" Maximum="2.00" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.50" Value="{Binding Preview3DTaaFxaaLumaEdgeScale, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DTaaFxaaLumaEdgeScaleTooltip}" IsEnabled="{Binding Preview3DEnablePreviewTaa}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DTaaFxaaLumaThreshold}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DTaaFxaaLumaThresholdTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.001" Maximum="0.120" SmallChange="0.001" LargeChange="0.010" TickFrequency="0.02" Value="{Binding Preview3DTaaFxaaLumaThreshold, Mode=TwoWay}" Increment="0.001" FormatString="F3" ToolTip.Tip="{Binding Strings.Preview3DTaaFxaaLumaThresholdTooltip}" IsEnabled="{Binding Preview3DEnablePreviewTaa}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                    </StackPanel>
                                                </ctrls:FlyoutSection>
                                                <ctrls:FlyoutSection Header="{Binding Strings.Preview3DLightingSection}" FlyoutMaxWidth="720">
                                                    <StackPanel Spacing="8">
                                                        <CheckBox IsChecked="{Binding Preview3DEnableShadows, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableShadowsTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DEnableShadows}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                        <CheckBox IsChecked="{Binding Preview3DEnableShadowCascades, Mode=TwoWay}"
                                                                  IsEnabled="{Binding Preview3DEnableShadows}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableShadowCascadesTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DEnableShadowCascades}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DTimeOfDayHours}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DTimeOfDayHoursTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0" Maximum="24" SmallChange="0.25" LargeChange="1" TickFrequency="3" Value="{Binding Preview3DTimeOfDayHours, Mode=TwoWay}" Increment="0.25" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DTimeOfDayHoursTooltip}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <CheckBox IsChecked="{Binding Preview3DAnimateTimeOfDay, Mode=TwoWay}"
                                                                  IsVisible="{Binding IsPreview3D}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DAnimateTimeOfDayTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DAnimateTimeOfDay}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DTimeOfDaySpeed}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DTimeOfDaySpeedTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.1" Maximum="4.0" SmallChange="0.1" LargeChange="0.5" TickFrequency="1.0" Value="{Binding Preview3DTimeOfDaySpeed, Mode=TwoWay}" Increment="0.1" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DTimeOfDaySpeedTooltip}" IsEnabled="{Binding Preview3DAnimateTimeOfDay}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DIblStrength}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DIblStrengthTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.0" Maximum="2.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.5" Value="{Binding Preview3DIblStrength, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DIblStrengthTooltip}" IsEnabled="{Binding Preview3DEnableIbl}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                    </StackPanel>
                                                </ctrls:FlyoutSection>
                                                <ctrls:FlyoutSection Header="{Binding Strings.Preview3DSpritesSection}" FlyoutMaxWidth="720">
                                                    <StackPanel Spacing="8">
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DSpriteThickness}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DSpriteThicknessTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="{x:Static stage:PreviewStageConstants.SpriteThicknessMin}" Maximum="{x:Static stage:PreviewStageConstants.SpriteThicknessMax}" SmallChange="{x:Static stage:PreviewStageConstants.SpriteThicknessStep}" LargeChange="0.01" TickFrequency="0.02" Value="{Binding Preview3DSpriteThickness, Mode=TwoWay}" Increment="0.002" FormatString="F3" ToolTip.Tip="{Binding Strings.Preview3DSpriteThicknessTooltip}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DSpritePlaneCount}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DSpritePlaneCountTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="1" Maximum="8" SmallChange="1" LargeChange="1" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding Preview3DSpritePlaneCount, Mode=TwoWay}" Increment="1" FormatString="0.##" ToolTip.Tip="{Binding Strings.Preview3DSpritePlaneCountTooltip}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                    </StackPanel>
                                                </ctrls:FlyoutSection>
                                            </StackPanel>
                                            <StackPanel Spacing="8" MinWidth="0">
                                                <ctrls:FlyoutSection Header="{Binding Strings.Preview3DAnimationSection}" FlyoutMaxWidth="720">
                                                    <StackPanel Spacing="8">
                                                        <CheckBox Content="{Binding Strings.Preview3DAutoRotate}"
                                                                  IsChecked="{Binding Preview3DAutoRotate, Mode=TwoWay}"
                                                                  IsEnabled="{Binding IsPreview3D}" />
                                                        <CheckBox Content="{Binding Strings.Preview3DEnableEntityAnimation}"
                                                                  IsChecked="{Binding Preview3DEnableEntityAnimation, Mode=TwoWay}"
                                                                  IsEnabled="{Binding IsPreview3D}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableEntityAnimationTooltip}" />
                                                        <CheckBox Content="{Binding Strings.Preview3DPauseEntityIdleAnimation}"
                                                                  IsChecked="{Binding Preview3DPauseEntityIdleAnimation, Mode=TwoWay}"
                                                                  IsEnabled="{Binding Preview3DEnableEntityAnimation}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DPauseEntityIdleAnimationTooltip}" />
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DEntityAnimationSpeed}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DEntityAnimationSpeedTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.00" Maximum="4.00" SmallChange="0.05" LargeChange="0.20" TickFrequency="0.5" Value="{Binding Preview3DEntityAnimationSpeed, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DEntityAnimationSpeedTooltip}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DEntityAnimationAmplitude}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DEntityAnimationAmplitudeTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.00" Maximum="2.00" SmallChange="0.05" LargeChange="0.10" TickFrequency="0.25" Value="{Binding Preview3DEntityAnimationAmplitude, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DEntityAnimationAmplitudeTooltip}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                    </StackPanel>
                                                </ctrls:FlyoutSection>
                                                <ctrls:FlyoutSection Header="{Binding Strings.Preview3DEntitiesSection}" FlyoutMaxWidth="720">
                                                    <StackPanel Spacing="8">
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DEntityAlphaMode}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DEntityAlphaModeTooltip}" />
                                                            <ComboBox Grid.Column="1" MinWidth="160" HorizontalAlignment="Left" ItemsSource="{x:Static vm:MainWindowViewModel.Preview3DEntityAlphaModeOptions}" SelectedIndex="{Binding Preview3DEntityAlphaMode, Mode=TwoWay}" ToolTip.Tip="{Binding Strings.Preview3DEntityAlphaModeTooltip}" />
                                                        </Grid>
                                                        <CheckBox Content="{Binding Strings.Preview3DEnableEntityLabPbrShading}"
                                                                  IsChecked="{Binding Preview3DEnableEntityLabPbrShading, Mode=TwoWay}"
                                                                  IsEnabled="{Binding IsPreview3D}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableEntityLabPbrShadingTooltip}" />
                                                        <CheckBox Content="{Binding Strings.Preview3DEnableEntityParallax}"
                                                                  IsChecked="{Binding Preview3DEnableEntityParallax, Mode=TwoWay}"
                                                                  IsEnabled="{Binding IsPreview3D}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableEntityParallaxTooltip}" />
                                                    </StackPanel>
                                                </ctrls:FlyoutSection>
                                                <ctrls:FlyoutSection Header="{Binding Strings.Preview3DGrassSection}" FlyoutMaxWidth="720">
                                                    <StackPanel Spacing="8">
                                                        <TextBlock Text="{Binding Strings.Preview3DGrassColormap}" TextWrapping="Wrap" />
                                                        <Image Source="{Binding Preview3DGrassColormapImage}"
                                                               Stretch="Uniform"
                                                               MaxHeight="72"
                                                               HorizontalAlignment="Stretch" />
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DGrassColormapTemperature}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DGrassColormapTemperatureTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.1" TickFrequency="0.1" Value="{Binding Preview3DGrassColormapTemperature, Mode=TwoWay}" Increment="0.01" FormatString="0.##" ToolTip.Tip="{Binding Strings.Preview3DGrassColormapTemperatureTooltip}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DGrassColormapDownfall}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DGrassColormapDownfallTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.1" TickFrequency="0.1" Value="{Binding Preview3DGrassColormapDownfall, Mode=TwoWay}" Increment="0.01" FormatString="0.##" ToolTip.Tip="{Binding Strings.Preview3DGrassColormapDownfallTooltip}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <TextBlock Text="{Binding Preview3DGrassColormapSampleText}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="11"
                                                                   Opacity="0.85"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </ctrls:FlyoutSection>
                                            </StackPanel>
                                            <StackPanel Spacing="8" MinWidth="0">
                                                <ctrls:FlyoutSection Header="{Binding Strings.Preview3DParallaxSection}" FlyoutMaxWidth="720">
                                                    <StackPanel Spacing="8">
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DParallaxHeightStrength}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DParallaxHeightStrengthTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.00" Maximum="1.00" SmallChange="0.005" LargeChange="0.05" TickFrequency="0.10" Value="{Binding Preview3DParallaxHeightStrength, Mode=TwoWay}" Increment="0.005" FormatString="F3" ToolTip.Tip="{Binding Strings.Preview3DParallaxHeightStrengthTooltip}" IsEnabled="{Binding Preview3DEnableParallax}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DParallaxTraceLayers}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DParallaxTraceLayersTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="8" Maximum="128" SmallChange="4" LargeChange="16" TickFrequency="8" IsSnapToTickEnabled="True" Value="{Binding Preview3DParallaxTraceLayers, Mode=TwoWay}" Increment="4" FormatString="0" ToolTip.Tip="{Binding Strings.Preview3DParallaxTraceLayersTooltip}" IsEnabled="{Binding Preview3DEnableParallax}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DParallaxRefineSteps}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DParallaxRefineStepsTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0" Maximum="8" SmallChange="1" LargeChange="1" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding Preview3DParallaxRefineSteps, Mode=TwoWay}" Increment="1" FormatString="0" ToolTip.Tip="{Binding Strings.Preview3DParallaxRefineStepsTooltip}" IsEnabled="{Binding Preview3DEnableParallax}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DParallaxMaxUvShift}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DParallaxMaxUvShiftTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.05" Maximum="0.75" SmallChange="0.01" LargeChange="0.05" TickFrequency="0.10" Value="{Binding Preview3DParallaxMaxUvShift, Mode=TwoWay}" Increment="0.01" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DParallaxMaxUvShiftTooltip}" IsEnabled="{Binding Preview3DEnableParallax}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <CheckBox IsChecked="{Binding Preview3DEnableTessellationDisplacement, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableTessellationDisplacementTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DEnableTessellationDisplacement}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DTessellationLevel}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DTessellationLevelTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="1" Maximum="16" SmallChange="1" LargeChange="2" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding Preview3DTessellationLevel, Mode=TwoWay}" Increment="1" FormatString="0" ToolTip.Tip="{Binding Strings.Preview3DTessellationLevelTooltip}" IsEnabled="{Binding Preview3DEnableTessellationDisplacement}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DTessellationDisplacementStrength}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DTessellationDisplacementStrengthTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.00" Maximum="0.20" SmallChange="0.002" LargeChange="0.01" TickFrequency="0.02" Value="{Binding Preview3DTessellationDisplacementStrength, Mode=TwoWay}" Increment="0.002" FormatString="F3" ToolTip.Tip="{Binding Strings.Preview3DTessellationDisplacementStrengthTooltip}" IsEnabled="{Binding Preview3DEnableTessellationDisplacement}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <CheckBox IsChecked="{Binding Preview3DEnableParallaxShadow, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableParallaxShadowTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DEnableParallaxShadow}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DParallaxShadowSamples}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DParallaxShadowSamplesTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="4" Maximum="64" SmallChange="2" LargeChange="8" TickFrequency="4" IsSnapToTickEnabled="True" Value="{Binding Preview3DParallaxShadowSamples, Mode=TwoWay}" Increment="2" FormatString="0" ToolTip.Tip="{Binding Strings.Preview3DParallaxShadowSamplesTooltip}" IsEnabled="{Binding Preview3DEnableParallaxShadow}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DParallaxShadowSoftness}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DParallaxShadowSoftnessTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.00" Maximum="4.00" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.50" Value="{Binding Preview3DParallaxShadowSoftness, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DParallaxShadowSoftnessTooltip}" IsEnabled="{Binding Preview3DEnableParallaxShadow}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <CheckBox IsChecked="{Binding Preview3DEnableParallaxAo, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableParallaxAoTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DEnableParallaxAo}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DParallaxAoStrength}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DParallaxAoStrengthTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.00" Maximum="2.00" SmallChange="0.02" LargeChange="0.10" TickFrequency="0.20" Value="{Binding Preview3DParallaxAoStrength, Mode=TwoWay}" Increment="0.02" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DParallaxAoStrengthTooltip}" IsEnabled="{Binding Preview3DEnableParallaxAo}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                    </StackPanel>
                                                </ctrls:FlyoutSection>
                                                <ctrls:FlyoutSection Header="{Binding Strings.Preview3DWorldSection}" FlyoutMaxWidth="720">
                                                    <StackPanel Spacing="8">
                                                        <CheckBox IsChecked="{Binding Preview3DShowGrid, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DShowGridTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DShowGrid}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                        <CheckBox IsChecked="{Binding Preview3DShowGroundMesh, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DShowGroundMeshTooltip}">
                                                            <TextBlock Text="{Binding Strings.Preview3DShowGroundMesh}" TextWrapping="Wrap" />
                                                        </CheckBox>
                                                    </StackPanel>
                                                </ctrls:FlyoutSection>
                                                <ctrls:FlyoutSection Header="{Binding Strings.Preview3DCameraExpanderSection}" FlyoutMaxWidth="720">
                                                    <StackPanel Spacing="8">
                                                        <CheckBox Content="{Binding Strings.Preview3DShowAxes}"
                                                                  IsChecked="{Binding Preview3DShowAxes, Mode=TwoWay}"
                                                                  IsEnabled="{Binding IsPreview3D}" />
                                                        <CheckBox Content="{Binding Strings.Preview3DShowFpsCounter}"
                                                                  IsChecked="{Binding Preview3DShowFpsCounter, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DShowFpsCounterTooltip}"
                                                                  IsEnabled="{Binding IsPreview3D}" />
                                                        <CheckBox Content="{Binding Strings.Preview3DCapFpsAt60}"
                                                                  IsChecked="{Binding Preview3DCapFpsAt60, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DCapFpsAt60Tooltip}"
                                                                  IsEnabled="{Binding IsPreview3D}" />
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCameraOrbitSensitivity}" TextWrapping="Wrap" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.001" Maximum="0.04" SmallChange="0.0005" LargeChange="0.002" Value="{Binding Preview3DCameraOrbitSensitivity, Mode=TwoWay}" Increment="0.0005" FormatString="0.##" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCameraPanSensitivity}" TextWrapping="Wrap" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.0005" Maximum="0.02" SmallChange="0.0002" LargeChange="0.001" Value="{Binding Preview3DCameraPanSensitivity, Mode=TwoWay}" Increment="0.0002" FormatString="0.##" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCameraZoomSensitivity}" TextWrapping="Wrap" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.04" Maximum="0.35" SmallChange="0.01" LargeChange="0.03" Value="{Binding Preview3DCameraZoomSensitivity, Mode=TwoWay}" Increment="0.01" FormatString="0.##" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCameraOrbitBoomDistance}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DCameraOrbitBoomDistanceTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="1.05" Maximum="120" SmallChange="0.25" LargeChange="2" Value="{Binding Preview3DCameraOrbitBoomDistance, Mode=TwoWay}" Increment="0.25" FormatString="0.##" ToolTip.Tip="{Binding Strings.Preview3DCameraOrbitBoomDistanceTooltip}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCameraFlyLookSensitivity}" TextWrapping="Wrap" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.001" Maximum="0.04" SmallChange="0.0005" LargeChange="0.002" Value="{Binding Preview3DCameraFlyLookSensitivity, Mode=TwoWay}" Increment="0.0005" FormatString="0.##" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCameraFlyMoveSpeed}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DCameraFlyMoveSpeedTooltip}" />
                                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="0.25" Maximum="4" SmallChange="0.05" LargeChange="0.25" Value="{Binding Preview3DCameraFlyMoveSpeed, Mode=TwoWay}" Increment="0.05" FormatString="0.##" ToolTip.Tip="{Binding Strings.Preview3DCameraFlyMoveSpeedTooltip}" HorizontalAlignment="Left" />
                                                        </Grid>
                                                        <CheckBox Content="{Binding Strings.Preview3DCameraInvertLookY}"
                                                                  IsChecked="{Binding Preview3DCameraInvertLookY, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DCameraInvertLookYTooltip}" />
                                                        <CheckBox Content="{Binding Strings.Preview3DCameraFlySmoothAcceleration}"
                                                                  IsChecked="{Binding Preview3DCameraFlySmoothAcceleration, Mode=TwoWay}"
                                                                  ToolTip.Tip="{Binding Strings.Preview3DCameraFlySmoothAccelerationTooltip}" />
                                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCameraResetKey}" TextWrapping="Wrap" />
                                                            <ComboBox Grid.Column="1" MinWidth="140" HorizontalAlignment="Left"
                                                                      ItemsSource="{Binding Preview3DCameraResetKeyChoices}"
                                                                      SelectedItem="{Binding Preview3DCameraResetKey, Mode=TwoWay}" />
                                                        </Grid>
                                                    </StackPanel>
                                                </ctrls:FlyoutSection>
                                            </StackPanel>
                                        </ctrls:ReflowColumnsPanel>

                                        <Border Margin="0,8,0,0" Padding="0,8,0,0"
                                                BorderThickness="0,1,0,0"
                                                BorderBrush="{Binding CardBorderBrush}">
                                            <StackPanel Spacing="10" MinWidth="0">
                                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.Preview3DSkyDomeSection}" TextWrapping="Wrap" />
                                                <ctrls:ReflowColumnsPanel MaxColumns="3" MinColumnWidth="240" ColumnSpacing="16" MinWidth="0">
                                                    <StackPanel Spacing="8" MinWidth="0">
                                                        <ctrls:FlyoutSection Header="{Binding Strings.Preview3DAtmosphereSection}" FlyoutMaxWidth="720">
                                                            <StackPanel Spacing="8">
                                                                <CheckBox IsChecked="{Binding Preview3DEnableAtmosphericSky, Mode=TwoWay}"
                                                                          ToolTip.Tip="{Binding Strings.Preview3DEnableAtmosphericSkyTooltip}">
                                                                    <TextBlock Text="{Binding Strings.Preview3DEnableAtmosphericSky}" TextWrapping="Wrap" />
                                                                </CheckBox>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DAtmosphereTurbidity}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereTurbidityTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="1.2" Maximum="10.0" SmallChange="0.1" LargeChange="0.5" TickFrequency="1.0" Value="{Binding Preview3DAtmosphereTurbidity, Mode=TwoWay}" Increment="0.1" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereTurbidityTooltip}" IsEnabled="{Binding Preview3DEnableAtmosphericSky}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DAtmosphereHorizonFalloff}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereHorizonFalloffTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.25" Maximum="4.0" SmallChange="0.05" LargeChange="0.2" TickFrequency="0.5" Value="{Binding Preview3DAtmosphereHorizonFalloff, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereHorizonFalloffTooltip}" IsEnabled="{Binding Preview3DEnableAtmosphericSky}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DAtmosphereSkyExposure}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereSkyExposureTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.1" Maximum="3.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.5" Value="{Binding Preview3DAtmosphereSkyExposure, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereSkyExposureTooltip}" IsEnabled="{Binding Preview3DEnableAtmosphericSky}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DHorizonFogStrength}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DHorizonFogStrengthTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.0" Maximum="2.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.5" Value="{Binding Preview3DHorizonFogStrength, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DHorizonFogStrengthTooltip}" IsEnabled="{Binding Preview3DEnableAtmosphericSky}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DGodRayStrength}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DGodRayStrengthTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.0" Maximum="2.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.5" Value="{Binding Preview3DGodRayStrength, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DGodRayStrengthTooltip}" IsEnabled="{Binding Preview3DEnableGodRays}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </ctrls:FlyoutSection>
                                                        <ctrls:FlyoutSection Header="{Binding Strings.Preview3DCloudSection}" IsEnabled="{Binding Preview3DEnableVolumetricClouds}" FlyoutMaxWidth="720">
                                                            <StackPanel Spacing="8">
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DVolumetricQuality}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DVolumetricQualityTooltip}" />
                                                                    <ComboBox Grid.Column="1" MinWidth="160" HorizontalAlignment="Left" ItemsSource="{Binding Preview3DVolumetricQualityOptions}" SelectedIndex="{Binding Preview3DVolumetricQuality, Mode=TwoWay}" ToolTip.Tip="{Binding Strings.Preview3DVolumetricQualityTooltip}" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCloudDensity}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DCloudDensityTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0" Maximum="2" SmallChange="0.02" LargeChange="0.1" Value="{Binding Preview3DCloudDensity, Mode=TwoWay}" Increment="0.02" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DCloudDensityTooltip}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCloudCoverageScale}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DCloudCoverageScaleTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0" Maximum="2" SmallChange="0.02" LargeChange="0.1" Value="{Binding Preview3DCloudCoverageScale, Mode=TwoWay}" Increment="0.02" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DCloudCoverageScaleTooltip}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCloudLayerHeight}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DCloudLayerHeightTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="-12" Maximum="48" SmallChange="0.5" LargeChange="4" Value="{Binding Preview3DCloudLayerHeight, Mode=TwoWay}" Increment="0.5" FormatString="F1" ToolTip.Tip="{Binding Strings.Preview3DCloudLayerHeightTooltip}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCloudVolumeHeight}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DCloudVolumeHeightTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="4" Maximum="96" SmallChange="1" LargeChange="8" Value="{Binding Preview3DCloudVolumeHeight, Mode=TwoWay}" Increment="1" FormatString="F0" ToolTip.Tip="{Binding Strings.Preview3DCloudVolumeHeightTooltip}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCloudVolumeSize}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DCloudVolumeSizeTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="8" Maximum="256" SmallChange="4" LargeChange="32" Value="{Binding Preview3DCloudVolumeSize, Mode=TwoWay}" Increment="4" FormatString="F0" ToolTip.Tip="{Binding Strings.Preview3DCloudVolumeSizeTooltip}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCloudWindSpeed}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DCloudWindSpeedTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0" Maximum="12" SmallChange="0.1" LargeChange="1" Value="{Binding Preview3DCloudWindSpeed, Mode=TwoWay}" Increment="0.1" FormatString="F1" ToolTip.Tip="{Binding Strings.Preview3DCloudWindSpeedTooltip}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCloudWindHeading}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DCloudWindHeadingTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="-180" Maximum="180" SmallChange="1" LargeChange="15" Value="{Binding Preview3DCloudWindHeadingDegrees, Mode=TwoWay}" Increment="1" FormatString="F0" ToolTip.Tip="{Binding Strings.Preview3DCloudWindHeadingTooltip}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCloudCirrusStrength}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DCloudCirrusStrengthTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0" Maximum="2" SmallChange="0.02" LargeChange="0.1" Value="{Binding Preview3DCloudCirrusStrength, Mode=TwoWay}" Increment="0.02" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DCloudCirrusStrengthTooltip}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </ctrls:FlyoutSection>
                                                    </StackPanel>
                                                    <StackPanel Spacing="8" MinWidth="0">
                                                        <ctrls:FlyoutSection Header="{Binding Strings.Preview3DSunSection}" FlyoutMaxWidth="720">
                                                            <StackPanel Spacing="8">
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DAtmosphereSunIntensity}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereSunIntensityTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.2" Maximum="64.0" SmallChange="0.2" LargeChange="1.0" TickFrequency="4.0" Value="{Binding Preview3DAtmosphereSunIntensity, Mode=TwoWay}" Increment="0.2" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereSunIntensityTooltip}" IsEnabled="{Binding Preview3DEnableAtmosphericSky}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DAtmosphereSunDiscBrightness}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereSunDiscBrightnessTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.0" Maximum="4.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.5" Value="{Binding Preview3DAtmosphereSunDiscBrightness, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereSunDiscBrightnessTooltip}" IsEnabled="{Binding Preview3DEnableAtmosphericSky}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DAtmosphereSunDiscStrength}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereSunDiscStrengthTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.0" Maximum="2.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.5" Value="{Binding Preview3DAtmosphereSunDiscStrength, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereSunDiscStrengthTooltip}" IsEnabled="{Binding Preview3DEnableAtmosphericSky}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DAtmosphereSunDiscSize}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereSunDiscSizeTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.05" Maximum="2.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.5" Value="{Binding Preview3DAtmosphereSunDiscSize, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereSunDiscSizeTooltip}" IsEnabled="{Binding Preview3DEnableAtmosphericSky}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </ctrls:FlyoutSection>
                                                        <ctrls:FlyoutSection Header="{Binding Strings.Preview3DMoonSection}" FlyoutMaxWidth="720">
                                                            <StackPanel Spacing="8">
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DAtmosphereMoonDiscStrength}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereMoonDiscStrengthTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.0" Maximum="4.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.5" Value="{Binding Preview3DAtmosphereMoonDiscStrength, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereMoonDiscStrengthTooltip}" IsEnabled="{Binding Preview3DEnableAtmosphericSky}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DAtmosphereMoonDiscSize}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereMoonDiscSizeTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.05" Maximum="3.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.5" Value="{Binding Preview3DAtmosphereMoonDiscSize, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereMoonDiscSizeTooltip}" IsEnabled="{Binding Preview3DEnableAtmosphericSky}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DAtmosphereMoonGlowStrength}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereMoonGlowStrengthTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.0" Maximum="4.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.5" Value="{Binding Preview3DAtmosphereMoonGlowStrength, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereMoonGlowStrengthTooltip}" IsEnabled="{Binding Preview3DEnableAtmosphericSky}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DAtmosphereMoonTextureSharpness}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereMoonTextureSharpnessTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.0" Maximum="4.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.5" Value="{Binding Preview3DAtmosphereMoonTextureSharpness, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DAtmosphereMoonTextureSharpnessTooltip}" IsEnabled="{Binding Preview3DEnableAtmosphericSky}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DMoonWorldLightIntensity}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DMoonWorldLightIntensityTooltip}" />
                                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.0" Maximum="8.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="1.0" Value="{Binding Preview3DMoonWorldLightIntensity, Mode=TwoWay}" Increment="0.05" FormatString="F2" ToolTip.Tip="{Binding Strings.Preview3DMoonWorldLightIntensityTooltip}" HorizontalAlignment="Left" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </ctrls:FlyoutSection>
                                                    </StackPanel>
                                                </ctrls:ReflowColumnsPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{Binding Strings.TabSettings}">
                    <!-- Match other tabs' HorizontalScrollBarVisibility=Auto; cap content width to viewport so Appearance WrapPanel wraps instead of one long row. -->
                    <ScrollViewer x:Name="SettingsTabScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <Grid MinWidth="0" HorizontalAlignment="Stretch"
                          MaxWidth="{Binding #SettingsTabScrollViewer.Viewport.Width}">
                    <StackPanel Margin="0,12,0,0" Spacing="12" MinWidth="0" HorizontalAlignment="Stretch">
                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="12" MinWidth="0">
                            <StackPanel Spacing="10" MinWidth="0">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.Output}" TextWrapping="Wrap" />
                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8" MinWidth="0">
                                    <Button Grid.Row="0" Grid.Column="0"
                                            VerticalAlignment="Center"
                                            Content="{Binding Strings.Browse}"
                                            Click="BrowseOutput_Click" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Classes="path-entry" MinWidth="0"
                                             Watermark="{Binding Strings.OutputFolderWatermark}"
                                             Text="{Binding OutputDirectory, Mode=TwoWay}" />

                                    <TextBox Grid.Row="1" Grid.Column="1" Classes="path-entry" MinWidth="0"
                                             IsReadOnly="True" Watermark="{Binding Strings.OutputPathWatermark}"
                                             Text="{Binding OutputZipPath}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="12" MinWidth="0">
                            <StackPanel Spacing="10" MinWidth="0">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.Engine}" TextWrapping="Wrap" />

                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10" MinWidth="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" MinWidth="0" MaxWidth="720" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MaxThreads}"
                                               ToolTip.Tip="{Binding Strings.MaxThreadsTooltip}" />
                                    <ctrls:OverlaySlider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="{Binding MaxThreadsMax}" SmallChange="1" LargeChange="1" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding MaxThreads, Mode=TwoWay}" Increment="1" FormatString="0.##" ToolTip.Tip="{Binding Strings.MaxThreadsTooltip}" HorizontalAlignment="Left" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.TempFolder}"
                                               ToolTip.Tip="{Binding Strings.TempFolderTooltip}" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Classes="path-entry" MinWidth="0" Margin="0,2,0,0"
                                             Watermark="{Binding Strings.TempFolderWatermark}"
                                             Text="{Binding TempDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip.Tip="{Binding Strings.TempFolderTooltip}" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text=" " />

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MinecraftAssetsFolder}"
                                               ToolTip.Tip="{Binding Strings.MinecraftAssetsFolderTooltip}" />
                                    <TextBox Grid.Row="2" Grid.Column="1" Classes="path-entry" MinWidth="0" Margin="0,2,0,0"
                                             Watermark="{Binding Strings.MinecraftAssetsFolderWatermark}"
                                             Text="{Binding MinecraftAssetsDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip.Tip="{Binding Strings.MinecraftAssetsFolderTooltip}" />
                                    <Button Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="8,2,0,0"
                                            Content="{Binding Strings.Browse}"
                                            Click="BrowseMinecraftAssets_Click"
                                            ToolTip.Tip="{Binding Strings.MinecraftAssetsFolderTooltip}" />
                                </Grid>

                                <CheckBox IsChecked="{Binding UseLegacyExtractor, Mode=TwoWay}"
                                    ToolTip.Tip="{Binding Strings.UseLegacyExtractorTooltip}">
                                    <TextBlock Text="{Binding Strings.UseLegacyExtractor}" TextWrapping="Wrap" />
                                </CheckBox>

                                <CheckBox IsChecked="{Binding PreferOnnxTensorRtExecutionProvider, Mode=TwoWay}"
                                    ToolTip.Tip="{Binding Strings.OnnxPreferTensorRtTooltip}">
                                    <TextBlock Text="{Binding Strings.OnnxPreferTensorRt}" TextWrapping="Wrap" />
                                </CheckBox>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock VerticalAlignment="Center" Text="{Binding Strings.DebugMode}" TextWrapping="Wrap" />
                                    <ToggleSwitch VerticalAlignment="Center"
                                                  OnContent=""
                                                  OffContent=""
                                                  IsChecked="{Binding DebugMode, Mode=TwoWay}" />
                                </StackPanel>

                                <Button HorizontalAlignment="Left"
                                        Command="{Binding ForceInvalidateShaderCacheCommand}"
                                        ToolTip.Tip="{Binding Strings.ForceShaderCacheInvalidationTooltip}">
                                    <TextBlock Text="{Binding Strings.ForceShaderCacheInvalidation}" TextWrapping="Wrap" />
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="12" MinWidth="0">
                            <StackPanel Spacing="10" MinWidth="0">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.Appearance}" TextWrapping="Wrap" />
                                <WrapPanel Orientation="Horizontal" ItemSpacing="16" LineSpacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock VerticalAlignment="Center" Text="{Binding Strings.ColorScheme}"
                                                   ToolTip.Tip="{Binding Strings.UiThemeTooltip}" />
                                        <ComboBox Width="220" ItemsSource="{Binding ColorSchemeOptions}"
                                            SelectedItem="{Binding SelectedColorSchemeOption, Mode=TwoWay}"
                                            ToolTip.Tip="{Binding Strings.UiThemeTooltip}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:FoliageModeOption">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock VerticalAlignment="Center" Text="{Binding Strings.Language}"
                                                   ToolTip.Tip="{Binding Strings.UiLanguageTooltip}" />
                                        <ComboBox Width="160" ItemsSource="{Binding SupportedLanguages}"
                                            SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                            ToolTip.Tip="{Binding Strings.UiLanguageTooltip}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:LanguageOption">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock VerticalAlignment="Center" Text="{Binding Strings.UiScaling}"
                                                   ToolTip.Tip="{Binding Strings.UiScalingTooltip}" />
                                        <ComboBox Width="120" MinWidth="100" MaxWidth="160" VerticalAlignment="Center"
                                                  ItemsSource="{Binding UiScaleOptions}"
                                                  SelectedItem="{Binding SelectedUiScaleOption, Mode=TwoWay}"
                                                  ToolTip.Tip="{Binding Strings.UiScalingTooltip}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:FoliageModeOption">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{Binding Strings.TabDebug}" IsVisible="{Binding DebugMode}">
                    <ScrollViewer x:Name="DebugTabScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <Grid MinWidth="0" HorizontalAlignment="Stretch"
                              MaxWidth="{Binding #DebugTabScrollViewer.Viewport.Width}">
                            <StackPanel Margin="0,12,0,0" Spacing="12" MinWidth="0" HorizontalAlignment="Stretch">
                                <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="12" MinWidth="0">
                                    <StackPanel Spacing="8" MinWidth="0">
                                        <CheckBox IsChecked="{Binding PreviewBrickProbeDebug, Mode=TwoWay}"
                                                  ToolTip.Tip="{Binding Strings.PreviewBrickProbeDebugTooltip}">
                                            <TextBlock Text="{Binding Strings.PreviewBrickProbeDebug}" TextWrapping="Wrap" />
                                        </CheckBox>

                                        <TextBlock FontWeight="SemiBold" Text="{Binding Strings.SpecularDebugSection}" Margin="0,4,0,0"
                                                   TextWrapping="Wrap"
                                                   IsVisible="{Binding UseMlSpecularPredictor}" />
                                        <StackPanel Spacing="8" IsVisible="{Binding UseMlSpecularPredictor}">
                                            <CheckBox IsChecked="{Binding SpecularDebugDisableHeuristicSpecular, Mode=TwoWay}"
                                                      ToolTip.Tip="{Binding Strings.SpecularDebugDisableHeuristicSpecularTooltip}">
                                                <TextBlock Text="{Binding Strings.SpecularDebugDisableHeuristicSpecular}" TextWrapping="Wrap" />
                                            </CheckBox>
                                            <CheckBox IsChecked="{Binding SpecularDebugSkipSpecularRemap, Mode=TwoWay}"
                                                      ToolTip.Tip="{Binding Strings.SpecularDebugSkipSpecularRemapTooltip}">
                                                <TextBlock Text="{Binding Strings.SpecularDebugSkipSpecularRemap}" TextWrapping="Wrap" />
                                            </CheckBox>
                                            <CheckBox IsChecked="{Binding SpecularDebugVerboseSpecularMl, Mode=TwoWay}"
                                                      ToolTip.Tip="{Binding Strings.SpecularDebugVerboseSpecularMlTooltip}">
                                                <TextBlock Text="{Binding Strings.SpecularDebugVerboseSpecularMl}" TextWrapping="Wrap" />
                                            </CheckBox>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="12" MinWidth="0">
                                    <StackPanel Spacing="8" MinWidth="0">
                                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Strings.Preview3DPreviewDebugSection}" TextWrapping="Wrap" />
                                        <CheckBox IsChecked="{Binding Preview3DShowCelestialDebug, Mode=TwoWay}"
                                                  IsVisible="{Binding IsPreview3D}"
                                                  ToolTip.Tip="{Binding Strings.Preview3DShowCelestialDebugTooltip}">
                                            <TextBlock Text="{Binding Strings.Preview3DShowCelestialDebug}" TextWrapping="Wrap" />
                                        </CheckBox>
                                        <ctrls:FlyoutSection Header="{Binding Strings.Preview3DGodRayDebugSection}" FlyoutMaxWidth="720">
                                            <StackPanel Spacing="8">
                                                <CheckBox IsChecked="{Binding Preview3DGodRayStabilizeDebug, Mode=TwoWay}"
                                                          IsEnabled="{Binding Preview3DEnableGodRays}"
                                                          ToolTip.Tip="{Binding Strings.Preview3DGodRayStabilizeDebugTooltip}">
                                                    <TextBlock Text="{Binding Strings.Preview3DGodRayStabilizeDebug}" TextWrapping="Wrap" />
                                                </CheckBox>
                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DGodRayDebugDensity}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DGodRayDebugDensityTooltip}" />
                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.0" Maximum="1.0" SmallChange="0.02" LargeChange="0.1" TickFrequency="0.25" Value="{Binding Preview3DGodRayDebugDensity, Mode=TwoWay}" Increment="0.02" FormatString="F2" IsEnabled="{Binding Preview3DEnableGodRays}" HorizontalAlignment="Left" />
                                                </Grid>
                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DGodRayScatterGain}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DGodRayScatterGainTooltip}" />
                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.0" Maximum="12.0" SmallChange="0.1" LargeChange="1.0" TickFrequency="2.0" Value="{Binding Preview3DGodRayScatterGain, Mode=TwoWay}" Increment="0.1" FormatString="F2" IsEnabled="{Binding Preview3DEnableGodRays}" HorizontalAlignment="Left" />
                                                </Grid>
                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DGodRayExtinction}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DGodRayExtinctionTooltip}" />
                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0.05" Maximum="6.0" SmallChange="0.05" LargeChange="0.5" TickFrequency="1.0" Value="{Binding Preview3DGodRayExtinction, Mode=TwoWay}" Increment="0.05" FormatString="F2" IsEnabled="{Binding Preview3DEnableGodRays}" HorizontalAlignment="Left" />
                                                </Grid>
                                            </StackPanel>
                                        </ctrls:FlyoutSection>
                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DLightYawDegrees}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DLightYawDegreesTooltip}" />
                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="-180" Maximum="180" SmallChange="1" LargeChange="10" TickFrequency="30" Value="{Binding Preview3DLightYawDegrees, Mode=TwoWay}" Increment="1" FormatString="F1" ToolTip.Tip="{Binding Strings.Preview3DLightYawDegreesTooltip}" HorizontalAlignment="Left" />
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0" IsVisible="{Binding IsPreview3D}">
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DLightPitchDegrees}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DLightPitchDegreesTooltip}" />
                                            <ctrls:OverlaySlider Grid.Column="1" Minimum="-89" Maximum="89" SmallChange="1" LargeChange="5" TickFrequency="15" Value="{Binding Preview3DLightPitchDegrees, Mode=TwoWay}" Increment="1" FormatString="F1" ToolTip.Tip="{Binding Strings.Preview3DLightPitchDegreesTooltip}" HorizontalAlignment="Left" />
                                        </Grid>
                                        <ctrls:FlyoutSection Header="{Binding Strings.Preview3DCloudDebugSection}" IsEnabled="{Binding Preview3DEnableVolumetricClouds}" FlyoutMaxWidth="720">
                                            <StackPanel Spacing="8">
                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCloudDebugView}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DCloudDebugViewTooltip}" />
                                                    <ComboBox Grid.Column="1" MinWidth="160" HorizontalAlignment="Left" ItemsSource="{Binding Preview3DCloudDebugViewOptions}" SelectedIndex="{Binding Preview3DCloudDebugView, Mode=TwoWay}" ToolTip.Tip="{Binding Strings.Preview3DCloudDebugViewTooltip}" />
                                                </Grid>
                                                <CheckBox IsChecked="{Binding Preview3DCloudDisableTemporal, Mode=TwoWay}"
                                                          ToolTip.Tip="{Binding Strings.Preview3DCloudDisableTemporalTooltip}">
                                                    <TextBlock Text="{Binding Strings.Preview3DCloudDisableTemporal}" TextWrapping="Wrap" />
                                                </CheckBox>
                                                <CheckBox IsChecked="{Binding Preview3DCloudFreezeWind, Mode=TwoWay}"
                                                          ToolTip.Tip="{Binding Strings.Preview3DCloudFreezeWindTooltip}">
                                                    <TextBlock Text="{Binding Strings.Preview3DCloudFreezeWind}" TextWrapping="Wrap" />
                                                </CheckBox>
                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" MinWidth="0">
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.Preview3DCloudMarchSteps}" TextWrapping="Wrap" ToolTip.Tip="{Binding Strings.Preview3DCloudMarchStepsTooltip}" />
                                                    <ctrls:OverlaySlider Grid.Column="1" Minimum="0" Maximum="64" SmallChange="1" LargeChange="4" TickFrequency="8" IsSnapToTickEnabled="True" Value="{Binding Preview3DCloudMarchStepOverride, Mode=TwoWay}" Increment="1" FormatString="0" ToolTip.Tip="{Binding Strings.Preview3DCloudMarchStepsTooltip}" HorizontalAlignment="Left" />
                                                </Grid>
                                            </StackPanel>
                                        </ctrls:FlyoutSection>
                                        <CheckBox Content="{Binding Strings.Preview3DEnableLegacyEntityWobble}"
                                                  IsChecked="{Binding Preview3DEnableLegacyEntityWobble, Mode=TwoWay}"
                                                  IsEnabled="{Binding Preview3DEnableEntityAnimation}"
                                                  ToolTip.Tip="{Binding Strings.Preview3DEnableLegacyEntityWobbleTooltip}" />
                                    </StackPanel>
                                </Border>

                                <Border CornerRadius="8" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="12" MinWidth="0">
                                    <ctrls:FlyoutSection Header="{Binding Strings.EditAiModels}" FlyoutMaxWidth="720">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding Strings.EditAiModelsWarning}"
                                                       TextWrapping="Wrap"
                                                       Opacity="0.9" />
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Strings.MlSpecularModelPath}"
                                                       TextWrapping="Wrap" />
                                            <TextBox Classes="path-entry" MinWidth="0"
                                                     Watermark="{Binding Strings.MlSpecularModelPathWatermark}"
                                                     Text="{Binding MlSpecularModelPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Strings.MlSpecularPerResolutionHeader}"
                                                       TextWrapping="Wrap"
                                                       ToolTip.Tip="{Binding Strings.MlSpecularPerResolutionTooltip}" />
                                            <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="8">
                                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MlResolution16x16}" />
                                                <TextBox Grid.Row="0" Grid.Column="1" Classes="path-entry" MinWidth="0"
                                                         Watermark="{Binding Strings.MlSpecularModelPathWatermark}"
                                                         Text="{Binding MlSpecularModelPath16, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MlResolution32x32}" />
                                                <TextBox Grid.Row="1" Grid.Column="1" Classes="path-entry" MinWidth="0"
                                                         Watermark="{Binding Strings.MlSpecularModelPathWatermark}"
                                                         Text="{Binding MlSpecularModelPath32, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MlResolution64x64}" />
                                                <TextBox Grid.Row="2" Grid.Column="1" Classes="path-entry" MinWidth="0"
                                                         Watermark="{Binding Strings.MlSpecularModelPathWatermark}"
                                                         Text="{Binding MlSpecularModelPath64, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MlResolution128x128}" />
                                                <TextBox Grid.Row="3" Grid.Column="1" Classes="path-entry" MinWidth="0"
                                                         Watermark="{Binding Strings.MlSpecularModelPathWatermark}"
                                                         Text="{Binding MlSpecularModelPath128, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Strings.MlResolution256x256}" />
                                                <TextBox Grid.Row="4" Grid.Column="1" Classes="path-entry" MinWidth="0"
                                                         Watermark="{Binding Strings.MlSpecularModelPathWatermark}"
                                                         Text="{Binding MlSpecularModelPath256, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                        </StackPanel>
                                    </ctrls:FlyoutSection>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

                <Button x:Name="JumpToTopButton"
                        Width="42" Height="42"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,18"
                        Opacity="0"
                        IsVisible="False"
                        IsHitTestVisible="False"
                        Background="#00000000"
                        BorderThickness="0"
                        ZIndex="2"
                        Click="JumpToTopButton_Click">
                    <TextBlock Text="&#x2191;" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
                </Grid>
            </Grid>

            <!-- Draggable splitter: 8px hit area; 1px line drawn on top (no nested Grid so splitter sees main Grid) -->
            <GridSplitter Grid.Column="1"
                          Background="Transparent"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="LeftSide"
                          HorizontalAlignment="Stretch" />
            <Border Grid.Column="1" Width="1" HorizontalAlignment="Right" Background="{Binding CardBorderBrush}"
                    IsHitTestVisible="False" />

            <!-- Preview + log: right column, persistent -->
            <Border Grid.Row="0" Grid.Column="2"
                    MinWidth="0"
                    MinHeight="0"
                    VerticalAlignment="Stretch"
                    ClipToBounds="True"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="1,0,0,0"
                    Padding="12">
                <Grid RowDefinitions="Auto,2*,Auto,1*" RowSpacing="8" MinWidth="0" MinHeight="0" ClipToBounds="True">
                    <StackPanel Orientation="Vertical" Spacing="4" MinWidth="0">
                        <TextBlock Text="{Binding Strings.PreviewPanelTitle}" FontWeight="SemiBold" Foreground="{Binding ForegroundBrush}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding PreviewTextureName}"
                                   Foreground="{Binding ForegroundBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   Opacity="0.9" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" VerticalAlignment="Center" MinWidth="0">
                            <WrapPanel Grid.Column="0"
                                       Orientation="Horizontal"
                                       ItemSpacing="8"
                                       LineSpacing="6"
                                       VerticalAlignment="Center"
                                       MinWidth="0">
                                <TextBlock Text="{Binding Strings.PreviewModeLabel}"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding ForegroundBrush}"
                                           Opacity="0.85"
                                           TextWrapping="Wrap" />
                                <ComboBox MinWidth="100"
                                          MaxWidth="200"
                                          SelectedIndex="{Binding PreviewDisplayMode}"
                                          VerticalAlignment="Center">
                                    <ComboBoxItem Content="{Binding Strings.PreviewMode2D}" />
                                    <ComboBoxItem Content="{Binding Strings.PreviewMode3D}" />
                                </ComboBox>
                                <Button Content="{Binding Strings.UvDebugButton}"
                                        VerticalAlignment="Center"
                                        Padding="10,2"
                                        IsVisible="{Binding DebugMode}"
                                        Click="OpenUvDebugWindow_Click" />
                                <Button Content="{Binding Strings.EntityDebugButton}"
                                        VerticalAlignment="Center"
                                        Padding="10,2"
                                        IsVisible="{Binding DebugMode}"
                                        Click="OpenEntityPreviewDebugWindow_Click" />
                            </WrapPanel>
                            <Button Grid.Column="1"
                                    Classes="preview-help-btn"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding IsPreview3D}"
                                    Background="{Binding CardBackground}"
                                    BorderBrush="{Binding CardBorderBrush}"
                                    BorderThickness="1"
                                    ToolTip.Tip="{Binding Strings.Preview3DCameraSection}"
                                    Click="OpenPreview3DCameraHelpWindow_Click">
                                <PathIcon Width="15"
                                          Height="15"
                                          Foreground="{Binding ForegroundBrush}"
                                          Data="{StaticResource PreviewCameraHelpIcon}" />
                            </Button>
                        </Grid>
                        <Border IsVisible="{Binding PreviewBrickProbeDebug}"
                                CornerRadius="4"
                                BorderBrush="{Binding CardBorderBrush}"
                                BorderThickness="1"
                                Padding="6"
                                MaxHeight="140">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding PreviewBrickProbeDebugText}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Foreground="{Binding ForegroundBrush}"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                    <Grid Grid.Row="1" ClipToBounds="True" MinHeight="80">
                        <Image IsVisible="{Binding IsPreview2D}"
                               Source="{Binding PreviewImage}"
                               Stretch="Uniform" />
                        <ctrls:GlPbrPreviewControl x:Name="GlPbrPreview"
                                                   IsVisible="{Binding IsPreview3D}"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Stretch"
                                                   MinHeight="120" />
                        <Border IsVisible="{Binding Preview3DGpuInitOverlayVisible}"
                                Background="#AA101018"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                ZIndex="3">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Spacing="8">
                                <TextBlock FontSize="13"
                                           Foreground="#F0FFFFFF"
                                           HorizontalAlignment="Center"
                                           Text="{Binding Preview3DGpuInitOverlayText}" />
                                <ProgressBar Width="220"
                                             Height="6"
                                             Minimum="0"
                                             Maximum="1"
                                             Value="{Binding Preview3DGpuInitProgressFraction}"
                                             IsIndeterminate="{Binding Preview3DGpuInitProgressIndeterminate}"
                                             Foreground="#88FFFFFF"
                                             Background="#33FFFFFF" />
                            </StackPanel>
                        </Border>
                        <TextBlock IsVisible="{Binding IsPreview3D}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Margin="8"
                                   ZIndex="2"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="#E8FFFFFF"
                                   Text="{Binding Preview3DCameraDebugText}"
                                   TextWrapping="Wrap"
                                   MaxWidth="520" />
                        <Border IsVisible="{Binding IsPreview3DFpsCounterVisible}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="8"
                                ZIndex="2"
                                Background="#66000000"
                                CornerRadius="4"
                                Padding="6,3">
                            <TextBlock FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="#F0FFFFFF"
                                       Text="{Binding Preview3DFpsCounterText}" />
                        </Border>
                    </Grid>
                    <StackPanel Grid.Row="2"
                                Orientation="Vertical"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding IsPreviewPoseSelectorVisible}">
                            <TextBlock Text="{Binding Strings.PreviewPoseLabel}"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding ForegroundBrush}"
                                       Opacity="0.85" />
                            <ComboBox MinWidth="220"
                                      ItemsSource="{Binding PreviewPoseOptions}"
                                      SelectedValue="{Binding SelectedPreviewPoseId, Mode=TwoWay}"
                                      SelectedValueBinding="{Binding Id}"
                                      DisplayMemberBinding="{Binding DisplayName}"
                                      VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding IsPreviewSizeSelectorVisible}">
                            <TextBlock Text="{Binding Strings.PreviewSizeLabel}"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding ForegroundBrush}"
                                       Opacity="0.85" />
                            <ComboBox MinWidth="160"
                                      ItemsSource="{Binding PreviewSizeOptions}"
                                      SelectedValue="{Binding SelectedPreviewSizeId, Mode=TwoWay}"
                                      SelectedValueBinding="{Binding Id}"
                                      DisplayMemberBinding="{Binding DisplayName}"
                                      VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding IsPreviewContextTypeSelectorVisible}">
                            <TextBlock Text="{Binding Strings.PreviewContextTypeLabel}"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding ForegroundBrush}"
                                       Opacity="0.85" />
                            <ComboBox MinWidth="180"
                                      ItemsSource="{Binding PreviewContextTypeOptions}"
                                      SelectedValue="{Binding SelectedPreviewContextTypeId, Mode=TwoWay}"
                                      SelectedValueBinding="{Binding Id}"
                                      DisplayMemberBinding="{Binding DisplayName}"
                                      VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                    <Grid Grid.Row="3" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="6" MinWidth="0" MinHeight="0">
                        <TextBlock Text="{Binding ConversionScanDebugText}"
                                   Foreground="{Binding ForegroundBrush}"
                                   Opacity="0.78"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding IsConverting}" />
                        <TextBlock Grid.Row="1" Text="{Binding ExploreMlDebugText}"
                                   Foreground="{Binding ForegroundBrush}"
                                   Opacity="0.78"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                        <WrapPanel Grid.Row="2" Orientation="Horizontal" ItemSpacing="8" LineSpacing="6" VerticalAlignment="Center">
                            <TextBlock VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding ForegroundBrush}"
                                       Text="{Binding Strings.Log}"
                                       TextWrapping="Wrap" />
                            <Button Content="{Binding Strings.OpenLogFolder}"
                                    Padding="8,2"
                                    VerticalAlignment="Center"
                                    Click="OpenLogFolder_Click" />
                        </WrapPanel>
                        <Border Grid.Row="3" CornerRadius="6" BorderBrush="{Binding CardBorderBrush}" BorderThickness="1" Padding="6" MinHeight="0">
                            <ScrollViewer x:Name="LogScrollViewer"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          MinHeight="72">
                                <SelectableTextBlock Text="{Binding LogText}"
                                                     FontFamily="Consolas"
                                                     FontSize="11"
                                                     TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{Binding WindowBackground}" Padding="12" MinWidth="0">
            <DockPanel LastChildFill="True" MinWidth="0">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="{Binding Strings.Cancel}" Command="{Binding CancelCommand}" IsEnabled="{Binding IsConverting}" />
                    <Button Content="{Binding Strings.Convert}" Command="{Binding ConvertCommand}" />
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0,0,8,0" MinWidth="0">
                    <Grid MinWidth="0" ColumnSpacing="8" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding StatusText}" TextWrapping="Wrap" Margin="0,0,0,4" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="10"
                                    VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,0,4">
                            <TextBlock Text="{Binding ConversionElapsedText}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ConversionTotalText}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ConversionEtaText}" VerticalAlignment="Center"
                                       Foreground="{Binding ForegroundBrush}" TextAlignment="Right" />
                        </StackPanel>
                        <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Minimum="0" Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}"
                                     Height="16" Foreground="{Binding AccentBrush}" MinHeight="16" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </DockPanel>
        </Border>
        </Grid>
    </Border>
        </LayoutTransformControl>
        <!-- Resize grips (drawn on top); left, right, bottom, corners -->
        <Border Width="6" HorizontalAlignment="Left" VerticalAlignment="Stretch" Background="Transparent"
                Cursor="LeftSide" PointerPressed="ResizeWest_PointerPressed" />
        <Border Width="6" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent"
                Cursor="RightSide" PointerPressed="ResizeEast_PointerPressed" />
        <Border Height="6" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Background="Transparent"
                Cursor="BottomSide" PointerPressed="ResizeSouth_PointerPressed" />
        <Border Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent"
                Cursor="TopLeftCorner" PointerPressed="ResizeNorthWest_PointerPressed" />
        <Border Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent"
                Cursor="TopRightCorner" PointerPressed="ResizeNorthEast_PointerPressed" />
        <Border Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="Transparent"
                Cursor="BottomLeftCorner" PointerPressed="ResizeSouthWest_PointerPressed" />
        <Border Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent"
                Cursor="BottomRightCorner" PointerPressed="ResizeSouthEast_PointerPressed" />
    </Grid>

</Window>
